# Copy to .env when MariaDB and Redis are provided outside this Compose stack.
COMPOSE_PROJECT_NAME=vibe-wp
HTTP_PORT=8080

WORDPRESS_IMAGE=wordpress:7.0-php8.5-fpm
NGINX_IMAGE=nginx:1.29-alpine
WORDPRESS_RUNTIME_IMAGE=vibe-wp-wordpress
NGINX_RUNTIME_IMAGE=vibe-wp-nginx

WP_HOME=https://example.com
WP_SITEURL=https://example.com
WP_ENVIRONMENT_TYPE=production

WORDPRESS_DB_HOST=external-mariadb-host:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=replace-with-database-password
WORDPRESS_DB_CHARSET=utf8mb4
WORDPRESS_DB_COLLATE=
WORDPRESS_TABLE_PREFIX=wp_

WORDPRESS_AUTH_KEY=replace-with-generated-secret
WORDPRESS_SECURE_AUTH_KEY=replace-with-generated-secret
WORDPRESS_LOGGED_IN_KEY=replace-with-generated-secret
WORDPRESS_NONCE_KEY=replace-with-generated-secret
WORDPRESS_AUTH_SALT=replace-with-generated-secret
WORDPRESS_SECURE_AUTH_SALT=replace-with-generated-secret
WORDPRESS_LOGGED_IN_SALT=replace-with-generated-secret
WORDPRESS_NONCE_SALT=replace-with-generated-secret

WORDPRESS_DEBUG=
WP_DEBUG_LOG=0
WP_DEBUG_DISPLAY=0
SCRIPT_DEBUG=0
WP_CACHE=1
WP_MEMORY_LIMIT=256M
WP_MAX_MEMORY_LIMIT=512M
FORCE_SSL_ADMIN=1
DISABLE_WP_CRON=1
DISALLOW_FILE_EDIT=1
DISALLOW_FILE_MODS=0
AUTOMATIC_UPDATER_DISABLED=0
WP_AUTO_UPDATE_CORE=minor
FS_METHOD=direct
FS_CHMOD_DIR=0755
FS_CHMOD_FILE=0644
EMPTY_TRASH_DAYS=14
WP_POST_REVISIONS=10
WP_CONTENT_FIX_PERMISSIONS=1

WP_REDIS_HOST=external-redis-host
WP_REDIS_PORT=6379
WP_REDIS_SCHEME=tcp
WP_REDIS_PATH=
WP_REDIS_USERNAME=
WP_REDIS_PASSWORD=replace-with-redis-password
WP_REDIS_DATABASE=0
WP_REDIS_PREFIX=example-com:
WP_CACHE_KEY_SALT=example-com:
WP_REDIS_TIMEOUT=1
WP_REDIS_READ_TIMEOUT=1
WP_REDIS_RETRY_INTERVAL=100
WP_REDIS_CLIENT=phpredis
WP_REDIS_IGBINARY=0
WP_REDIS_MAXTTL=604800
WP_REDIS_SELECTIVE_FLUSH=1
WP_REDIS_GRACEFUL=1
WP_REDIS_FLUSH_TIMEOUT=5
WP_REDIS_DISABLE_METRICS=1
WP_REDIS_DISABLE_ADMINBAR=1
WP_REDIS_DISABLE_BANNERS=1
WP_REDIS_DISABLE_DROPIN_BANNERS=1
WP_REDIS_DISABLE_COMMENT=1
WP_REDIS_DISABLE_GROUP_FLUSH=0
WP_REDIS_DISABLED=0
WP_REDIS_GLOBAL_GROUPS=
WP_REDIS_IGNORED_GROUPS=
WP_REDIS_UNFLUSHABLE_GROUPS=
VIBE_WP_REDIS_EXTRA_GLOBAL_GROUPS=
VIBE_WP_REDIS_NON_PERSISTENT_GROUPS=
VIBE_WP_REDIS_UNFLUSHABLE_GROUPS=

PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=128M
PHP_POST_MAX_SIZE=128M
PHP_MAX_EXECUTION_TIME=120
PHP_MAX_INPUT_TIME=120
PHP_MAX_INPUT_VARS=5000
PHP_REALPATH_CACHE_SIZE=4096K
PHP_REALPATH_CACHE_TTL=600
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_ENABLE_CLI=1
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=32
PHP_OPCACHE_MAX_ACCELERATED_FILES=65000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=0
PHP_OPCACHE_REVALIDATE_FREQ=0
PHP_OPCACHE_JIT=0
PHP_OPCACHE_JIT_BUFFER_SIZE=0

PHP_FPM_PM=dynamic
PHP_FPM_PM_MAX_CHILDREN=24
PHP_FPM_PM_START_SERVERS=4
PHP_FPM_PM_MIN_SPARE_SERVERS=2
PHP_FPM_PM_MAX_SPARE_SERVERS=8
PHP_FPM_PM_MAX_REQUESTS=500
PHP_FPM_REQUEST_TERMINATE_TIMEOUT=120s
PHP_FPM_PM_PROCESS_IDLE_TIMEOUT=10s

NGINX_CLIENT_MAX_BODY_SIZE=128m
NGINX_CLIENT_BODY_BUFFER_SIZE=256k
NGINX_WORKER_CONNECTIONS=4096
NGINX_KEEPALIVE_TIMEOUT=65s
NGINX_KEEPALIVE_REQUESTS=1000
NGINX_CLIENT_HEADER_TIMEOUT=15s
NGINX_CLIENT_BODY_TIMEOUT=60s
NGINX_SEND_TIMEOUT=30s
NGINX_ACCESS_LOG=1
NGINX_GZIP=on
NGINX_GZIP_COMP_LEVEL=5
NGINX_GZIP_MIN_LENGTH=1024
NGINX_OPEN_FILE_CACHE=on
NGINX_OPEN_FILE_CACHE_MAX=10000
NGINX_OPEN_FILE_CACHE_INACTIVE=60s
NGINX_OPEN_FILE_CACHE_VALID=120s
NGINX_OPEN_FILE_CACHE_MIN_USES=2
NGINX_OPEN_FILE_CACHE_ERRORS=on
NGINX_STATIC_CACHE_CONTROL=public,max-age=2592000
NGINX_FASTCGI_CACHE_KEYS_ZONE_SIZE=128m
NGINX_FASTCGI_CACHE_TTL=10m
NGINX_FASTCGI_REDIRECT_CACHE_TTL=1m
NGINX_FASTCGI_CACHE_INACTIVE=60m
NGINX_FASTCGI_CACHE_MAX_SIZE=2g
NGINX_FASTCGI_CACHE_MIN_USES=1
NGINX_FASTCGI_CACHE_LOCK_TIMEOUT=10s
NGINX_FASTCGI_CONNECT_TIMEOUT=10s
NGINX_FASTCGI_SEND_TIMEOUT=120s
NGINX_FASTCGI_READ_TIMEOUT=120s
NGINX_ENABLE_HSTS=1

WP_CRON_INTERVAL=60
WORDPRESS_CONFIG_EXTRA=
