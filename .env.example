# Project
COMPOSE_PROJECT_NAME=vibe-wp
HTTP_PORT=8080
ADMINER_PORT=8081

# Image selection
WORDPRESS_IMAGE=wordpress:7.0-php8.5-fpm
NGINX_IMAGE=nginx:1.29-alpine
MARIADB_IMAGE=mariadb:12.3
REDIS_IMAGE=redis:8-alpine
WORDPRESS_RUNTIME_IMAGE=vibe-wp-wordpress
NGINX_RUNTIME_IMAGE=vibe-wp-nginx
MARIADB_RUNTIME_IMAGE=vibe-wp-mariadb
REDIS_RUNTIME_IMAGE=vibe-wp-redis

# Public site settings
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_ENVIRONMENT_TYPE=local

# WordPress install helper
WP_INSTALL_TITLE="Vibe WP"
WP_INSTALL_ADMIN_USER=admin
WP_INSTALL_ADMIN_PASSWORD=change-me
WP_INSTALL_ADMIN_EMAIL=admin@example.com
WP_INSTALL_LOCALE=en_US
WP_INSTALL_SKIP_EMAIL=1

# MariaDB
MARIADB_DATABASE=wordpress
MARIADB_USER=wordpress
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me
MARIADB_AUTO_UPGRADE=1

# WordPress database settings
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me
WORDPRESS_DB_CHARSET=utf8mb4
WORDPRESS_DB_COLLATE=
WORDPRESS_TABLE_PREFIX=wp_

# WordPress salts. Run `make init` to generate safe values.
WORDPRESS_AUTH_KEY=change-me
WORDPRESS_SECURE_AUTH_KEY=change-me
WORDPRESS_LOGGED_IN_KEY=change-me
WORDPRESS_NONCE_KEY=change-me
WORDPRESS_AUTH_SALT=change-me
WORDPRESS_SECURE_AUTH_SALT=change-me
WORDPRESS_LOGGED_IN_SALT=change-me
WORDPRESS_NONCE_SALT=change-me

# WordPress runtime flags
WORDPRESS_DEBUG=
WP_DEBUG_LOG=0
WP_DEBUG_DISPLAY=0
SCRIPT_DEBUG=0
WP_CACHE=1
WP_MEMORY_LIMIT=256M
WP_MAX_MEMORY_LIMIT=512M
FORCE_SSL_ADMIN=0
DISABLE_WP_CRON=1
DISALLOW_FILE_EDIT=1
DISALLOW_FILE_MODS=0
AUTOMATIC_UPDATER_DISABLED=0
WP_AUTO_UPDATE_CORE=minor
FS_METHOD=direct
FS_CHMOD_DIR=0755
FS_CHMOD_FILE=0644
EMPTY_TRASH_DAYS=14
WP_POST_REVISIONS=10
WP_CONTENT_FIX_PERMISSIONS=1
VIBE_WP_FORCE_NOINDEX=0
VIBE_WP_DISABLE_OUTBOUND_MAIL=0
VIBE_WP_INTERNAL_URL=http://nginx:8080

# WordPress baseline plugins and cleanup
VIBE_WP_REQUIRED_PLUGINS=redis-cache,ai,ai-provider-for-anthropic,ai-provider-for-google,ai-provider-for-openai
VIBE_WP_REMOVE_PLUGINS=hello,hello-dolly
VIBE_WP_REMOVE_THEMES=twentytwentythree,twentytwentyfour

# Optional WordPress 7.0 AI connector credentials
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Redis object cache
REDIS_PASSWORD=change-me
REDIS_BIND=0.0.0.0
REDIS_PORT=6379
REDIS_PROTECTED_MODE=yes
REDIS_DATABASES=16
REDIS_TCP_BACKLOG=1024
REDIS_TIMEOUT=0
REDIS_TCP_KEEPALIVE=60
REDIS_MAXCLIENTS=10000
REDIS_LOGLEVEL=notice
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lfu
REDIS_MAXMEMORY_SAMPLES=10
REDIS_LFU_LOG_FACTOR=10
REDIS_LFU_DECAY_TIME=1
REDIS_IO_THREADS=1
REDIS_IO_THREADS_DO_READS=yes
REDIS_SAVE=
REDIS_APPENDONLY=no
REDIS_APPENDFSYNC=everysec
REDIS_LAZYFREE_LAZY_EVICTION=yes
REDIS_LAZYFREE_LAZY_EXPIRE=yes
REDIS_LAZYFREE_LAZY_SERVER_DEL=yes
REDIS_LAZYFREE_LAZY_USER_DEL=yes
REDIS_LAZYFREE_LAZY_USER_FLUSH=yes
REDIS_ACTIVE_DEFRAG=yes
REDIS_ACTIVE_DEFRAG_IGNORE_BYTES=100mb
REDIS_ACTIVE_DEFRAG_THRESHOLD_LOWER=10
REDIS_ACTIVE_DEFRAG_THRESHOLD_UPPER=100
REDIS_ACTIVE_DEFRAG_CYCLE_MIN=1
REDIS_ACTIVE_DEFRAG_CYCLE_MAX=25
REDIS_HZ=10
REDIS_DYNAMIC_HZ=yes
REDIS_DISABLE_THP=yes
REDIS_JEMALLOC_BG_THREAD=yes
REDIS_SLOWLOG_LOG_SLOWER_THAN=10000
REDIS_SLOWLOG_MAX_LEN=256
REDIS_LATENCY_MONITOR_THRESHOLD=0
REDIS_NOFILE_SOFT_LIMIT=65535
REDIS_NOFILE_HARD_LIMIT=65535
WP_REDIS_HOST=redis
WP_REDIS_PORT=6379
WP_REDIS_SCHEME=tcp
WP_REDIS_PATH=
WP_REDIS_USERNAME=
WP_REDIS_PASSWORD=change-me
WP_REDIS_DATABASE=0
WP_REDIS_PREFIX=vibe-wp:
WP_CACHE_KEY_SALT=vibe-wp:
WP_REDIS_TIMEOUT=1
WP_REDIS_READ_TIMEOUT=1
WP_REDIS_RETRY_INTERVAL=100
WP_REDIS_CLIENT=phpredis
WP_REDIS_IGBINARY=0
WP_REDIS_MAXTTL=604800
WP_REDIS_SELECTIVE_FLUSH=1
WP_REDIS_GRACEFUL=1
WP_REDIS_FLUSH_TIMEOUT=5
WP_REDIS_DISABLE_METRICS=1
WP_REDIS_DISABLE_ADMINBAR=1
WP_REDIS_DISABLE_BANNERS=1
WP_REDIS_DISABLE_DROPIN_BANNERS=1
WP_REDIS_DISABLE_COMMENT=1
WP_REDIS_DISABLE_GROUP_FLUSH=0
WP_REDIS_DISABLED=0
WP_REDIS_GLOBAL_GROUPS=
WP_REDIS_IGNORED_GROUPS=
WP_REDIS_UNFLUSHABLE_GROUPS=
VIBE_WP_REDIS_EXTRA_GLOBAL_GROUPS=
VIBE_WP_REDIS_NON_PERSISTENT_GROUPS=
VIBE_WP_REDIS_UNFLUSHABLE_GROUPS=

# PHP runtime tuning
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=128M
PHP_POST_MAX_SIZE=128M
PHP_MAX_EXECUTION_TIME=120
PHP_MAX_INPUT_TIME=120
PHP_MAX_INPUT_VARS=5000
PHP_REALPATH_CACHE_SIZE=4096K
PHP_REALPATH_CACHE_TTL=600
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_ENABLE_CLI=1
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=32
PHP_OPCACHE_MAX_ACCELERATED_FILES=65000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1
PHP_OPCACHE_REVALIDATE_FREQ=2
PHP_OPCACHE_JIT=0
PHP_OPCACHE_JIT_BUFFER_SIZE=0

# PHP-FPM tuning
PHP_FPM_PM=dynamic
PHP_FPM_PM_MAX_CHILDREN=24
PHP_FPM_PM_START_SERVERS=4
PHP_FPM_PM_MIN_SPARE_SERVERS=2
PHP_FPM_PM_MAX_SPARE_SERVERS=8
PHP_FPM_PM_MAX_REQUESTS=500
PHP_FPM_REQUEST_TERMINATE_TIMEOUT=120s
PHP_FPM_PM_PROCESS_IDLE_TIMEOUT=10s

# Nginx tuning
NGINX_CLIENT_MAX_BODY_SIZE=128m
NGINX_CLIENT_BODY_BUFFER_SIZE=256k
NGINX_WORKER_CONNECTIONS=4096
NGINX_KEEPALIVE_TIMEOUT=65s
NGINX_KEEPALIVE_REQUESTS=1000
NGINX_CLIENT_HEADER_TIMEOUT=15s
NGINX_CLIENT_BODY_TIMEOUT=60s
NGINX_SEND_TIMEOUT=30s
NGINX_ACCESS_LOG=1
NGINX_GZIP=on
NGINX_GZIP_COMP_LEVEL=5
NGINX_GZIP_MIN_LENGTH=1024
NGINX_OPEN_FILE_CACHE=on
NGINX_OPEN_FILE_CACHE_MAX=10000
NGINX_OPEN_FILE_CACHE_INACTIVE=60s
NGINX_OPEN_FILE_CACHE_VALID=120s
NGINX_OPEN_FILE_CACHE_MIN_USES=2
NGINX_OPEN_FILE_CACHE_ERRORS=off
NGINX_STATIC_CACHE_CONTROL=public,max-age=2592000
# Page cache for anonymous GET/HEAD. off keeps PHP-FPM serving every request
# (no caching); the skip rules + cache zone stay valid either way. Changing this
# requires recreating the nginx container so the entrypoint re-renders the config.
NGINX_FASTCGI_CACHE=on
NGINX_FASTCGI_CACHE_KEYS_ZONE_SIZE=128m
NGINX_FASTCGI_CACHE_TTL=10m
NGINX_FASTCGI_REDIRECT_CACHE_TTL=1m
NGINX_FASTCGI_CACHE_INACTIVE=30m
NGINX_FASTCGI_CACHE_MAX_SIZE=1g
NGINX_FASTCGI_CACHE_MIN_USES=1
NGINX_FASTCGI_CACHE_LOCK_TIMEOUT=10s
NGINX_FASTCGI_CONNECT_TIMEOUT=10s
NGINX_FASTCGI_SEND_TIMEOUT=120s
NGINX_FASTCGI_READ_TIMEOUT=120s
NGINX_ENABLE_HSTS=0

# MariaDB tuning
MARIADB_CHARACTER_SET_SERVER=utf8mb4
MARIADB_COLLATION_SERVER=utf8mb4_unicode_ci
MARIADB_MAX_ALLOWED_PACKET=256M
MARIADB_MAX_CONNECTIONS=150
MARIADB_THREAD_CACHE_SIZE=100
MARIADB_TABLE_OPEN_CACHE=4000
MARIADB_TABLE_DEFINITION_CACHE=2000
MARIADB_OPEN_FILES_LIMIT=65535
MARIADB_NOFILE_SOFT_LIMIT=1048576
MARIADB_NOFILE_HARD_LIMIT=1048576
MARIADB_TMP_TABLE_SIZE=64M
MARIADB_MAX_HEAP_TABLE_SIZE=64M
MARIADB_SORT_BUFFER_SIZE=2M
MARIADB_JOIN_BUFFER_SIZE=2M
MARIADB_READ_BUFFER_SIZE=1M
MARIADB_READ_RND_BUFFER_SIZE=2M
MARIADB_ARIA_PAGECACHE_BUFFER_SIZE=128M
MARIADB_INNODB_BUFFER_POOL_SIZE=256M
MARIADB_INNODB_LOG_FILE_SIZE=256M
MARIADB_INNODB_LOG_BUFFER_SIZE=16M
MARIADB_INNODB_FLUSH_LOG_AT_TRX_COMMIT=1
MARIADB_INNODB_LINUX_AIO=aio
MARIADB_INNODB_FLUSH_NEIGHBORS=0
MARIADB_INNODB_IO_CAPACITY=400
MARIADB_INNODB_IO_CAPACITY_MAX=2000
MARIADB_INNODB_READ_IO_THREADS=4
MARIADB_INNODB_WRITE_IO_THREADS=4
MARIADB_INNODB_PURGE_THREADS=4
MARIADB_INNODB_STATS_PERSISTENT=ON
MARIADB_INNODB_BUFFER_POOL_DUMP_AT_SHUTDOWN=ON
MARIADB_INNODB_BUFFER_POOL_LOAD_AT_STARTUP=ON
MARIADB_INNODB_BUFFER_POOL_DUMP_PCT=25
MARIADB_PERFORMANCE_SCHEMA=OFF
MARIADB_SLOW_QUERY_LOG=OFF
MARIADB_SLOW_QUERY_LOG_FILE=/var/lib/mysql/mariadb-slow.log
MARIADB_LONG_QUERY_TIME=2
MARIADB_MIN_EXAMINED_ROW_LIMIT=100
MARIADB_LOG_QUERIES_NOT_USING_INDEXES=OFF

# Cron worker
WP_CRON_INTERVAL=60

# Optional raw PHP appended to wp-config.php after the generated helper functions.
WORDPRESS_CONFIG_EXTRA=
