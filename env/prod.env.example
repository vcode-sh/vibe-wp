# Copy to env/prod.env and replace every secret before deploying.
COMPOSE_PROJECT_NAME=vibe-wp-prod
HTTP_PORT=8080

WORDPRESS_IMAGE=wordpress:7.0-php8.5-fpm
NGINX_IMAGE=nginx:1.29-alpine
MARIADB_IMAGE=mariadb:12.3
REDIS_IMAGE=redis:8-alpine
WORDPRESS_RUNTIME_IMAGE=vibe-wp-wordpress
NGINX_RUNTIME_IMAGE=vibe-wp-nginx
MARIADB_RUNTIME_IMAGE=vibe-wp-mariadb
REDIS_RUNTIME_IMAGE=vibe-wp-redis

WP_HOME=https://example.com
WP_SITEURL=https://example.com
WP_ENVIRONMENT_TYPE=production

WP_INSTALL_TITLE="Vibe WP"
WP_INSTALL_ADMIN_USER=admin
WP_INSTALL_ADMIN_PASSWORD=replace-with-generated-password
WP_INSTALL_ADMIN_EMAIL=admin@example.com
WP_INSTALL_LOCALE=en_US
WP_INSTALL_SKIP_EMAIL=1

MARIADB_DATABASE=wordpress
MARIADB_USER=wordpress
MARIADB_PASSWORD=replace-with-generated-password
MARIADB_ROOT_PASSWORD=replace-with-generated-password
MARIADB_AUTO_UPGRADE=1

WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=replace-with-generated-password
WORDPRESS_DB_CHARSET=utf8mb4
WORDPRESS_DB_COLLATE=
WORDPRESS_TABLE_PREFIX=wp_

WORDPRESS_AUTH_KEY=replace-with-generated-secret
WORDPRESS_SECURE_AUTH_KEY=replace-with-generated-secret
WORDPRESS_LOGGED_IN_KEY=replace-with-generated-secret
WORDPRESS_NONCE_KEY=replace-with-generated-secret
WORDPRESS_AUTH_SALT=replace-with-generated-secret
WORDPRESS_SECURE_AUTH_SALT=replace-with-generated-secret
WORDPRESS_LOGGED_IN_SALT=replace-with-generated-secret
WORDPRESS_NONCE_SALT=replace-with-generated-secret

WP_CACHE=1
WP_MEMORY_LIMIT=256M
WP_MAX_MEMORY_LIMIT=512M
FORCE_SSL_ADMIN=1
DISABLE_WP_CRON=1
DISALLOW_FILE_EDIT=1
DISALLOW_FILE_MODS=0
AUTOMATIC_UPDATER_DISABLED=0
WP_AUTO_UPDATE_CORE=false
FS_METHOD=direct
FS_CHMOD_DIR=0755
FS_CHMOD_FILE=0644
WP_CONTENT_FIX_PERMISSIONS=1

REDIS_PASSWORD=replace-with-generated-password
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lfu
REDIS_IO_THREADS=2
WP_REDIS_HOST=redis
WP_REDIS_PORT=6379
WP_REDIS_SCHEME=tcp
WP_REDIS_PASSWORD=replace-with-generated-password
WP_REDIS_DATABASE=0
WP_REDIS_PREFIX=example-com-prod:
WP_CACHE_KEY_SALT=example-com-prod:
WP_REDIS_TIMEOUT=1
WP_REDIS_READ_TIMEOUT=1
WP_REDIS_RETRY_INTERVAL=100
WP_REDIS_CLIENT=phpredis
WP_REDIS_MAXTTL=604800
WP_REDIS_SELECTIVE_FLUSH=1
WP_REDIS_GRACEFUL=1
WP_REDIS_DISABLE_METRICS=1
WP_REDIS_DISABLE_ADMINBAR=1
WP_REDIS_DISABLE_BANNERS=1
WP_REDIS_DISABLE_COMMENT=1

NGINX_ENABLE_HSTS=1
NGINX_FASTCGI_CACHE_MAX_SIZE=2g

# Managed WordPress mode: plugins/themes can update in wp-admin.
# WordPress core remains image-managed and should be upgraded by changing WORDPRESS_IMAGE.
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1
PHP_OPCACHE_REVALIDATE_FREQ=60
VIBE_WP_FORCE_NOINDEX=0
VIBE_WP_DISABLE_OUTBOUND_MAIL=0
VIBE_WP_INTERNAL_URL=http://nginx:8080

VIBE_WP_REQUIRED_PLUGINS=redis-cache,ai,ai-provider-for-anthropic,ai-provider-for-google,ai-provider-for-openai
VIBE_WP_REMOVE_PLUGINS=hello,hello-dolly
VIBE_WP_REMOVE_THEMES=twentytwentythree,twentytwentyfour

OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Backups (local + optional off-server copy to S3/Cloudflare R2 via rclone) ---
# Local backup root (default backups/<env>/ when empty).
VIBE_BACKUP_DIR=
# Keep only the newest N backups locally and remotely (empty = keep all).
VIBE_BACKUP_RETENTION=7
# Set to 1 to also upload each backup to object storage.
VIBE_BACKUP_R2_ENABLED=0
VIBE_BACKUP_R2_BUCKET=
# Path prefix inside the bucket (default: the env name).
VIBE_BACKUP_R2_PREFIX=
# rclone remote (Cloudflare R2 endpoint: https://<account-id>.r2.cloudflarestorage.com).
RCLONE_CONFIG_R2_TYPE=s3
RCLONE_CONFIG_R2_PROVIDER=Cloudflare
RCLONE_CONFIG_R2_ACCESS_KEY_ID=
RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=
RCLONE_CONFIG_R2_ENDPOINT=
RCLONE_CONFIG_R2_ACL=private
RCLONE_CONFIG_R2_NO_CHECK_BUCKET=true
