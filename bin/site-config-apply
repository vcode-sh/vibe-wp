#!/usr/bin/env sh
set -eu
umask 077
# Persist per-site WordPress runtime settings into the selected environment's
# env file. These keys are rendered into wp-config by the WordPress image
# entrypoint (docker/wordpress/entrypoint.sh) on container start, so a restart
# is required for changes to take effect — the caller is responsible for that.
#
# The control panel injects the resolved values as environment variables (from
# its SQLite store) and runs this command. Only the managed keys below are
# touched; every other line is preserved verbatim. No secrets are involved or
# printed (these are boolean debug flags).
#
# The caller MUST declare which managed keys it is changing this call via
# VIBE_SITE_CONFIG_KEYS (space-separated). We only upsert keys that are BOTH in
# the fixed managed allowlist AND named in VIBE_SITE_CONFIG_KEYS — so a managed
# key that merely happens to be present in the inherited process environment
# (e.g. WP_DEBUG_LOG exported in the panel's own env) is never rewritten unless
# the caller explicitly asked to change it this call.

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"

vibe_require_env_file
file="${VIBE_ENV_FILE}"

# All edits are staged on a working copy that inherits the env file's mode and
# owner (cp -p), then swapped in with a single atomic rename. The real env file
# — which also holds the DB password and WP salts — is therefore never observed
# truncated or half-written, and never has its 0600 permissions widened.
work="${file}.vibe-apply.$$"
line="${work}.line"
trap 'rm -f "${work}" "${line}"' EXIT INT TERM
if [ -f "${file}" ]; then
  cp -p "${file}" "${work}"
else
  : > "${work}"
fi

# Replace `KEY=...` in place on the working copy, or append it when absent.
env_upsert() {
  key="$1"
  val="$2"
  # Env files are sourced with `set -a; . file`; a newline would split the value
  # into a second shell statement, so strip CR/LF defensively.
  val="$(printf '%s' "${val}" | tr -d '\r\n')"
  found=0
  {
    while IFS= read -r entry || [ -n "${entry}" ]; do
      case "${entry}" in
        "${key}="*)
          printf '%s=%s\n' "${key}" "${val}"
          found=1
          ;;
        *) printf '%s\n' "${entry}" ;;
      esac
    done < "${work}"
    [ "${found}" -eq 1 ] || printf '%s=%s\n' "${key}" "${val}"
  } > "${line}"
  cat "${line}" > "${work}"
}

# The fixed allowlist of keys this command is permitted to write. Each maps onto
# a vibe_wp_env_bool() lookup in the WordPress image entrypoint.
managed_keys="WP_DEBUG_LOG WP_DEBUG_DISPLAY SCRIPT_DEBUG"

# Membership test against a space-separated list (POSIX-safe, no arrays).
in_list() {
  needle="$1"
  list="$2"
  for item in ${list}; do
    [ "${item}" = "${needle}" ] && return 0
  done
  return 1
}

# Only rewrite keys that are BOTH managed AND explicitly named by the caller in
# VIBE_SITE_CONFIG_KEYS. A managed key that is only present via the inherited
# process environment (but not named) is left untouched. An unsupplied value is
# skipped too, so a partial save never blanks a flag the user did not change.
changed_keys="${VIBE_SITE_CONFIG_KEYS:-}"
for key in ${changed_keys}; do
  in_list "${key}" "${managed_keys}" || {
    echo "Refusing to write unmanaged key: ${key}" >&2
    exit 2
  }
  eval "val=\${${key}:-__VIBE_UNSET__}"
  [ "${val}" = "__VIBE_UNSET__" ] && continue
  env_upsert "${key}" "${val}"
done

# Atomic, same-filesystem swap into place.
mv -f "${work}" "${file}"
echo "Site configuration applied to ${file}"
