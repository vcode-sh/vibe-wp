#!/usr/bin/env sh
set -eu
umask 077
# Persist per-site WordPress runtime settings into the selected environment's
# env file. These keys are rendered into wp-config by the WordPress image
# entrypoint (docker/wordpress/entrypoint.sh) on container start, so a restart
# is required for changes to take effect — the caller is responsible for that.
#
# The control panel injects the resolved values as environment variables (from
# its SQLite store) and runs this command. Only the managed keys below are
# touched; every other line is preserved verbatim. No secrets are involved or
# printed (these are boolean debug flags).

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"

vibe_require_env_file
file="${VIBE_ENV_FILE}"

# All edits are staged on a working copy that inherits the env file's mode and
# owner (cp -p), then swapped in with a single atomic rename. The real env file
# — which also holds the DB password and WP salts — is therefore never observed
# truncated or half-written, and never has its 0600 permissions widened.
work="${file}.vibe-apply.$$"
line="${work}.line"
trap 'rm -f "${work}" "${line}"' EXIT INT TERM
if [ -f "${file}" ]; then
  cp -p "${file}" "${work}"
else
  : > "${work}"
fi

# Replace `KEY=...` in place on the working copy, or append it when absent.
env_upsert() {
  key="$1"
  val="$2"
  # Env files are sourced with `set -a; . file`; a newline would split the value
  # into a second shell statement, so strip CR/LF defensively.
  val="$(printf '%s' "${val}" | tr -d '\r\n')"
  found=0
  {
    while IFS= read -r entry || [ -n "${entry}" ]; do
      case "${entry}" in
        "${key}="*)
          printf '%s=%s\n' "${key}" "${val}"
          found=1
          ;;
        *) printf '%s\n' "${entry}" ;;
      esac
    done < "${work}"
    [ "${found}" -eq 1 ] || printf '%s=%s\n' "${key}" "${val}"
  } > "${line}"
  cat "${line}" > "${work}"
}

# Only rewrite keys the panel actually supplied, so an unrelated save never
# blanks a value the user did not touch. Each managed key maps onto a
# vibe_wp_env_bool() lookup in the WordPress image entrypoint.
for key in \
  WP_DEBUG_LOG \
  WP_DEBUG_DISPLAY \
  SCRIPT_DEBUG; do
  eval "val=\${${key}:-__VIBE_UNSET__}"
  [ "${val}" = "__VIBE_UNSET__" ] && continue
  env_upsert "${key}" "${val}"
done

# Atomic, same-filesystem swap into place.
mv -f "${work}" "${file}"
echo "Site configuration applied to ${file}"
