#!/usr/bin/env sh
set -eu
umask 077
# Persist per-site WordPress runtime settings into the selected environment's
# env file. These keys are rendered into wp-config by the WordPress image
# entrypoint (docker/wordpress/entrypoint.sh) on container start, so a restart
# is required for changes to take effect — the caller is responsible for that.
#
# The control panel injects the resolved values as environment variables (from
# its SQLite store) and runs this command. Only the managed keys below are
# touched; every other line is preserved verbatim. No secrets are involved or
# printed (these are boolean debug flags).
#
# The caller MUST declare which managed keys it is changing this call via
# VIBE_SITE_CONFIG_KEYS (space-separated). We only upsert keys that are BOTH in
# the fixed managed allowlist AND named in VIBE_SITE_CONFIG_KEYS — so a managed
# key that merely happens to be present in the inherited process environment
# (e.g. WP_DEBUG_LOG exported in the panel's own env) is never rewritten unless
# the caller explicitly asked to change it this call.

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"

vibe_require_env_file
file="${VIBE_ENV_FILE}"

# All edits are staged on a working copy that inherits the env file's mode and
# owner (cp -p), then swapped in with a single atomic rename. The real env file
# — which also holds the DB password and WP salts — is therefore never observed
# truncated or half-written, and never has its 0600 permissions widened.
work="${file}.vibe-apply.$$"
line="${work}.line"
trap 'rm -f "${work}" "${line}"' EXIT INT TERM
if [ -f "${file}" ]; then
  cp -p "${file}" "${work}"
else
  : > "${work}"
fi

# Single-quote-escape a value for safe inclusion in an env file that is later
# sourced (`set -a; . file`). Wraps in single quotes and rewrites each embedded
# single quote as '\'' so no value content can be interpreted as shell. This is
# defense in depth — managed values are also validated to 0/1 before reaching
# here, but the writer must not depend on the caller (a sourced `KEY=$(cmd)` runs
# as root via the WordPress image entrypoint / cron).
sq_escape() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

# Replace `KEY=...` in place on the working copy, or append it when absent.
env_upsert() {
  key="$1"
  val="$2"
  # Env files are sourced with `set -a; . file`; a newline would split the value
  # into a second shell statement, so strip CR/LF defensively.
  val="$(printf '%s' "${val}" | tr -d '\r\n')"
  # Single-quote-escape on write so a value can never be parsed as shell.
  quoted="$(sq_escape "${val}")"
  found=0
  {
    while IFS= read -r entry || [ -n "${entry}" ]; do
      case "${entry}" in
        "${key}="*)
          printf '%s=%s\n' "${key}" "${quoted}"
          found=1
          ;;
        *) printf '%s\n' "${entry}" ;;
      esac
    done < "${work}"
    [ "${found}" -eq 1 ] || printf '%s=%s\n' "${key}" "${quoted}"
  } > "${line}"
  cat "${line}" > "${work}"
}

# The fixed allowlist of keys this command is permitted to write. The boolean
# debug flags map onto vibe_wp_env_bool() lookups in the WordPress image
# entrypoint; WORDPRESS_IMAGE is the FROM build arg that fixes the PHP version
# and is only honored on a rebuild (vibe up --build), not a plain restart.
# DISALLOW_FILE_EDIT (entrypoint -> wp-config) and VIBE_WP_DISABLE_XMLRPC (read by
# the vibe-wp-environment MU plugin) are the one-click security hardening toggles;
# both are 0|1 booleans honored at container start, so a restart applies them.
# VIBE_LOG_MAX_SIZE / VIBE_LOG_MAX_FILE feed Docker Compose json-file logging.
managed_keys="WP_DEBUG_LOG WP_DEBUG_DISPLAY SCRIPT_DEBUG WORDPRESS_IMAGE NGINX_FASTCGI_CACHE DISALLOW_FILE_EDIT VIBE_WP_DISABLE_XMLRPC VIBE_LOG_MAX_SIZE VIBE_LOG_MAX_FILE"

# The curated allowlist of WordPress runtime images the panel may select. This
# MUST stay in lockstep with ALLOWED_WORDPRESS_IMAGES in the control panel
# (control-panel/packages/api/src/core-bridge/site-config-pure.ts). Because the
# env file is sourced as root, this shell — not the panel — is the real trust
# boundary: an image tag that is not EXACTLY one of these is rejected before any
# write, so an attacker-supplied `WORDPRESS_IMAGE=$(cmd)` can never land here.
allowed_images="wordpress:7.0-php8.5-fpm wordpress:7.0-php8.4-fpm wordpress:7.0-php8.3-fpm"
allowed_log_sizes="1m 5m 10m 25m 50m 100m"

# Membership test against a space-separated list (POSIX-safe, no arrays).
in_list() {
  needle="$1"
  list="$2"
  for item in ${list}; do
    [ "${item}" = "${needle}" ] && return 0
  done
  return 1
}

# Only rewrite keys that are BOTH managed AND explicitly named by the caller in
# VIBE_SITE_CONFIG_KEYS. A managed key that is only present via the inherited
# process environment (but not named) is left untouched. An unsupplied value is
# skipped too, so a partial save never blanks a flag the user did not change.
changed_keys="${VIBE_SITE_CONFIG_KEYS:-}"
for key in ${changed_keys}; do
  in_list "${key}" "${managed_keys}" || {
    echo "Refusing to write unmanaged key: ${key}" >&2
    exit 2
  }
  eval "val=\${${key}:-__VIBE_UNSET__}"
  [ "${val}" = "__VIBE_UNSET__" ] && continue
  # Validate PER KEY before writing — the writer must not trust the caller's
  # value, since env files are sourced as root (an unvalidated `KEY=$(cmd)` would
  # execute). The boolean debug flags accept only 0/1; WORDPRESS_IMAGE must be an
  # EXACT member of the curated image allowlist; NGINX_FASTCGI_CACHE is a literal
  # on|off (the nginx entrypoint normalizes/renders it). Anything else is a bug or
  # an injection attempt and is fatal.
  case "${key}" in
    WORDPRESS_IMAGE)
      in_list "${val}" "${allowed_images}" || {
        echo "Refusing to write disallowed WORDPRESS_IMAGE: ${val}" >&2
        exit 2
      }
      ;;
    NGINX_FASTCGI_CACHE)
      case "${val}" in
        on|off) : ;;
        *)
          echo "Refusing to write non-on/off value for ${key}: ${val}" >&2
          exit 2
          ;;
      esac
      ;;
    VIBE_LOG_MAX_SIZE)
      in_list "${val}" "${allowed_log_sizes}" || {
        echo "Refusing to write disallowed VIBE_LOG_MAX_SIZE: ${val}" >&2
        exit 2
      }
      ;;
    VIBE_LOG_MAX_FILE)
      case "${val}" in
        [1-9]|10) : ;;
        *)
          echo "Refusing to write out-of-range VIBE_LOG_MAX_FILE: ${val}" >&2
          exit 2
          ;;
      esac
      ;;
    *)
      case "${val}" in
        0|1) : ;;
        *)
          echo "Refusing to write non-boolean value for ${key}: ${val}" >&2
          exit 2
          ;;
      esac
      ;;
  esac
  env_upsert "${key}" "${val}"
done

# Atomic, same-filesystem swap into place.
mv -f "${work}" "${file}"
echo "Site configuration applied to ${file}"
