#!/usr/bin/env sh
set -eu

usage() {
  cat <<'USAGE'
Usage:
  ./bin/vibe <local|stage|prod|external> <command> [args...]

Commands:
  compose <args...>          Run docker compose for the selected environment
  config                     Validate the selected Compose config
  up [services...]           Start the selected environment
  down [args...]             Stop the selected environment
  restart [services...]      Restart services
  ps                         Show service status
  logs [args...]             Follow logs
  logs-recent [args...]      Print recent logs without following (does not hang)
  install                    Install WordPress and Redis Object Cache
  wp <args...>               Run WP-CLI
  backup [args...]           Create a DB and wp-content backup
  backup-verify <backup> [args...] Verify a backup without restoring it
  restore <backup> [args...] Restore a backup
  backups                    List available backups for this env (newest last)
  backups-remote             List off-server (R2) backups as restorable paths
  monitor [--quiet] [--json] [--no-notify]  Run health checks (uptime, disk, TLS, backups, containers); alert unless --no-notify
  security-status            Print host security posture as JSON (firewall, fail2ban, auto-updates)
  harden [--dry-run] [--ssh-key-only]  Apply host hardening (firewall, fail2ban, auto-updates)
  doctor-runtime             Run runtime checks
  perf-report                Print a read-only performance report
  smoke                      Run smoke tests
  cache-flush                Flush object cache and Nginx page cache
  refresh-from-prod --yes    Refresh this staging env from prod
  promote-files-to-prod --yes Promote managed plugin/theme files to prod
  env <KEY>                  Print a value from the selected env file
USAGE
}

if [ "$#" -lt 2 ]; then
  usage >&2
  exit 1
fi

export VIBE_ENV="$1"
shift

command="$1"
shift

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"
. "${VIBE_BIN_DIR}/lib/backup.sh"

case "${command}" in
  compose)
    vibe_compose "$@"
    ;;
  config)
    if [ ! -f "${VIBE_ENV_FILE}" ] && [ -f "${VIBE_ENV_FILE}.example" ]; then
      VIBE_ENV_FILE="${VIBE_ENV_FILE}.example"
    fi
    vibe_compose config >/dev/null
    echo "${VIBE_ENV} compose config ok"
    ;;
  up)
    vibe_require_env_file
    vibe_compose up -d --build "$@"
    if [ "$#" -eq 0 ] || printf '%s\n' "$@" | grep -qx wordpress; then
      vibe_compose restart nginx >/dev/null 2>&1 || true
    fi
    # Block until healthchecks pass (after the nginx restart), so callers like
    # smoke don't race a still-starting stack. Ignored if --wait is unsupported.
    vibe_compose up -d --wait --wait-timeout 180 "$@" >/dev/null 2>&1 || true
    ;;
  down)
    vibe_compose down "$@"
    ;;
  restart)
    vibe_compose restart "$@"
    ;;
  ps)
    vibe_compose ps "$@"
    ;;
  logs)
    # No --timestamps here: the live tail streams raw lines unparsed, so a
    # nanosecond RFC3339 prefix would render verbatim and clutter the view.
    # logs-recent keeps --timestamps because its output is parsed for the table.
    vibe_compose logs -f --tail=200 "$@"
    ;;
  logs-recent)
    # One-shot tail (no -f) so non-interactive callers like the installer UI
    # get the latest lines and the command returns instead of streaming forever.
    vibe_compose logs --no-color --timestamps --tail=200 "$@"
    ;;
  backups)
    # List available backups for this env, one per line, TAB-separated:
    # <path>\t<bytes>\t<location>\t<complete>
    # location: "both" if the backup also exists on the remote, else "local".
    # complete: "complete" if manifest.txt + declared db + wp-content archives exist, else "partial".
    _backup_root="$(backup_root)"

    # Build a set of remote basenames once (only when remote is enabled).
    _remote_basenames=""
    if backup_remote_enabled 2>/dev/null; then
      _remote_basenames="$(backup_list_remote 2>/dev/null | while IFS= read -r rpath; do
        [ -n "${rpath}" ] && basename "${rpath}"
      done)"
    fi

    ls -1d "${_backup_root}/"*/ 2>/dev/null | sed 's#/*$##' | while IFS= read -r dir; do
      [ -d "${dir}" ] || continue

      # Size in bytes (total for the dir).
      _bytes="$(du -sb "${dir}" 2>/dev/null | cut -f1)"
      [ -n "${_bytes}" ] || _bytes=0

      # Location: check if basename is among remote basenames.
      _name="$(basename "${dir}")"
      if printf '%s\n' "${_remote_basenames}" | grep -qx "${_name}" 2>/dev/null; then
        _loc="both"
      else
        _loc="local"
      fi

      # Completeness: manifest must exist and declare db + wp-content archives.
      _manifest="${dir}/manifest.txt"
      _complete="partial"
      if [ -f "${_manifest}" ]; then
        _db_file="$(grep '^database=' "${_manifest}" | cut -d= -f2 | tr -d '[:space:]')"
        _wc_file="$(grep '^wp_content=' "${_manifest}" | cut -d= -f2 | tr -d '[:space:]')"
        if [ -n "${_db_file}" ] && [ -n "${_wc_file}" ] && \
           [ -s "${dir}/${_db_file}" ] && [ -s "${dir}/${_wc_file}" ]; then
          _complete="complete"
        fi
      fi

      printf '%s\t%s\t%s\t%s\n' "${dir}" "${_bytes}" "${_loc}" "${_complete}"
    done || true
    ;;
  backups-remote)
    # List off-server (R2) backups as local-equivalent paths; restore auto-fetches.
    backup_list_remote || true
    ;;
  install)
    "${VIBE_BIN_DIR}/install-wordpress" "$@"
    ;;
  wp)
    vibe_wp "$@"
    ;;
  backup)
    "${VIBE_BIN_DIR}/backup" "$@"
    ;;
  backup-config-apply)
    "${VIBE_BIN_DIR}/backup-config-apply" "$@"
    ;;
  backup-test)
    "${VIBE_BIN_DIR}/backup-test" "$@"
    ;;
  notify-config-apply)
    "${VIBE_BIN_DIR}/notify-config-apply" "$@"
    ;;
  notify-test)
    "${VIBE_BIN_DIR}/notify-test" "$@"
    ;;
  backup-verify)
    "${VIBE_BIN_DIR}/backup-verify" "$@"
    ;;
  restore)
    "${VIBE_BIN_DIR}/restore" "$@"
    ;;
  doctor-runtime)
    "${VIBE_BIN_DIR}/doctor-runtime" "$@"
    ;;
  perf-report)
    "${VIBE_BIN_DIR}/perf-report" "$@"
    ;;
  smoke)
    "${VIBE_BIN_DIR}/smoke" "$@"
    ;;
  monitor)
    "${VIBE_BIN_DIR}/monitor" "$@"
    ;;
  security-status)
    "${VIBE_BIN_DIR}/security-status" "$@"
    ;;
  harden)
    "${VIBE_BIN_DIR}/harden" "$@"
    ;;
  cache-flush)
    vibe_wp cache flush >/dev/null || true
    vibe_clear_nginx_cache
    echo "Caches flushed for ${VIBE_ENV}."
    ;;
  refresh-from-prod)
    "${VIBE_BIN_DIR}/stage-refresh" --stage "${VIBE_ENV}" "$@"
    ;;
  promote-files-to-prod)
    "${VIBE_BIN_DIR}/stage-promote-files" --stage "${VIBE_ENV}" "$@"
    ;;
  env)
    if [ "$#" -ne 1 ]; then
      echo "Usage: ./bin/vibe ${VIBE_ENV} env <KEY>" >&2
      exit 1
    fi
    vibe_env_value "$1"
    printf '\n'
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: ${command}" >&2
    usage >&2
    exit 1
    ;;
esac
