#!/bin/sh
# vibe-panel-run — root-owned, sudoers-gated privilege boundary for the control panel.
#
# The panel server runs as the unprivileged `vibe-panel` user. The ONLY thing it
# may `sudo` is this wrapper (see /etc/sudoers.d/vibe-wp-panel), so this script is
# the single host-exec chokepoint and MUST validate every input before acting.
#
# SAFETY INVARIANTS (ENFORCED here at the root boundary — NOT assumptions about
# the unprivileged caller. A compromised panel must not gain anything beyond the
# narrow surface below, even though the panel-side already allowlists too):
#   - This file is installed root:root 0755 and is NEVER writable by vibe-panel.
#     If vibe-panel could rewrite it, the sudoers gate would be worthless.
#   - It never eval/execs arbitrary caller input. Subcommands are fixed; site
#     paths are validated against the PANEL_SITES_ROOTS allowlist; the env token
#     is checked against a fixed set; installer args must be exactly --headless-json.
#   - EXEC-TARGET OWNERSHIP (assert_root_owned): before running a site bin/vibe,
#     both the site dir and the bin/vibe file (and its symlink target, if any)
#     MUST be owned by root (uid 0) and NOT group/other-writable. Otherwise a
#     panel that could write into /opt|/srv could plant a malicious bin/vibe and
#     get root. We do NOT trust that the install tree is well-permissioned.
#   - OP RE-VALIDATION (validate_op / validate_arg): the op and every argument are
#     re-checked here against a FIXED allowlist mirroring exec.ts VIBE_OPS — we do
#     NOT trust the caller's allowlist. `wp` is restricted to the exact panel
#     subcommands (no eval/eval-file/db/etc). Flags + path-like args are bounded.
#   - `siteinfo` prints ONLY non-secret fields. It NEVER prints DB/Redis
#     passwords, WP salts, R2/monitor secrets, or any other env value.
#   - `support-bundle` (zero args) execs the root-owned bin/support-bundle
#     collector after assert_root_owned. That script emits a REDACTED gzip tar to
#     stdout (every text member is redacted BEFORE tar; only non-secret env keys
#     are read, never a `cat` of an env file). It is its OWN subcommand — NOT in
#     OP_ALLOWLIST (that is the per-site `vibe` surface).
#   - `panel-update` (zero args) runs `bin/panel update` DETACHED via systemd-run
#     so the panel's own self-restart at the end of the update cannot kill the
#     updater mid-flight. It is strictly allowlisted to EXACTLY `panel update`:
#     no other bin/panel subcommand (install/uninstall/reset-password) is
#     reachable. assert_root_owned guards a planted bin/panel. Its OWN subcommand
#     — NOT in OP_ALLOWLIST.
#   - `panel-domain <domain>` ADDS a custom domain to the control-panel Caddy site
#     ALONGSIDE the magic-DNS host (never replacing it) and adds it to the panel's
#     trusted origins. The domain is STRICTLY re-validated HERE at the root boundary
#     (validate_panel_domain — the load-bearing copy; the panel is the untrusted
#     caller) before resolving the root-owned bin/panel-domain-apply and exec'ing it
#     DETACHED via systemd-run (so the panel restart at the end survives). Its OWN
#     subcommand — NOT in OP_ALLOWLIST.
set -eu
# Force the C locale so every `case` charset guard (e.g. the slug regex
# *[!a-z0-9-]*) is strictly ASCII. In a UTF-8 locale a range like [a-z] can span
# accented collation characters, which would widen what a slug/version guard
# accepts. This is a defense-in-depth hardening of the root boundary.
export LC_ALL=C

# Roots under which a site install dir is allowed to live. The panel passes the
# same default; keeping it here too means the gate holds even if the caller lies.
PANEL_SITES_ROOTS="${PANEL_SITES_ROOTS:-/opt:/srv}"
# Installer binary the panel drives for provisioning. Fixed default mirrors the
# panel's PANEL_INSTALLER_BIN; only `--headless-json` may ever be passed.
PANEL_INSTALLER_BIN="${PANEL_INSTALLER_BIN:-/opt/vibe-wp-panel/bin/vibe-wp-installer}"
# Deployed source repo (where the shared-db ops live: bin/shared-db-*, bin/db-*,
# bin/lib/shared-db.sh). Fixed at this root boundary — a caller-supplied value is
# stripped by sudo's env_reset (PANEL_HOST_DIR is NOT in panel_env_keep), so the
# `shared-db` subcommand always resolves its scripts from this trusted default.
PANEL_HOST_DIR="${PANEL_HOST_DIR:-/opt/vibe-wp-src}"

die() {
  echo "vibe-panel-run: $1" >&2
  exit 1
}

# Canonicalize an EXISTING directory to its absolute, symlink-resolved path.
# Portable across GNU + BSD: `cd -P` resolves symlinks and `pwd` prints the
# canonical absolute path. Empty output means the dir does not exist / is not a
# directory (the caller then aborts). We deliberately avoid GNU-only realpath
# flags (-e/-m) so the validation behaves identically everywhere.
canonical_dir() {
  ( CDPATH='' cd -P -- "$1" 2>/dev/null && pwd ) || true
}

# Is the canonical path "$1" under one of the colon-separated PANEL_SITES_ROOTS
# roots? Pure prefix check on canonical paths (each root is canonicalized too,
# so a symlinked root still matches). A path equal to a root is NOT a site dir.
under_allowed_root() {
  candidate="$1"
  IFS=:
  for root in $PANEL_SITES_ROOTS; do
    [ -n "$root" ] || continue
    real_root="$(canonical_dir "$root")"
    [ -n "$real_root" ] || continue
    case "$candidate" in
      "$real_root"/*) unset IFS; return 0 ;;
    esac
  done
  unset IFS
  return 1
}

# Validate that $1 is a safe, allowlisted site install dir containing bin/vibe.
validate_site_dir() {
  dir="$1"
  case "$dir" in
    /*) : ;;                       # must be absolute
    *) die "site dir must be an absolute path" ;;
  esac
  case "$dir" in
    *..*) die "site dir must not contain '..'" ;;
  esac
  # Canonicalize AND require existence as a directory; symlinks are resolved here
  # so a symlink pointing outside the roots is caught by under_allowed_root.
  real="$(canonical_dir "$dir")"
  [ -n "$real" ] || die "site dir does not exist or is not a directory"
  under_allowed_root "$real" || die "site dir is outside the allowed roots"
  [ -x "$real/bin/vibe" ] || die "site dir has no bin/vibe entrypoint"
  SITE_DIR_REAL="$real"
}

# Validate the env token against the fixed set the stack supports.
validate_env() {
  case "$1" in
    local|stage|prod|external|shared-db) : ;;
    *) die "invalid env: $1" ;;
  esac
}

# Require that a filesystem path is owned by root (uid 0) and not group/other-
# writable. Deployed wrapper runs on Linux, so GNU `stat -c '%u'` and
# `find -perm /022` are available. Either check failing is fatal: an attacker
# who can write the exec target (or a dir letting them replace it) could get root.
assert_root_owned() {
  target="$1"
  what="$2"
  owner="$(stat -c '%u' -- "$target" 2>/dev/null || echo "")"
  [ "$owner" = "0" ] || die "$what is not root-owned (refusing to exec as root)"
  # -perm /022 matches if group-write OR other-write is set; any match -> reject.
  if [ -n "$(find "$target" -prune -perm /022 2>/dev/null)" ]; then
    die "$what is group/other-writable (refusing to exec as root)"
  fi
}

# Assert the site's bin/vibe is a safe, root-owned exec target. Guards against a
# panel that can write into /opt|/srv planting a malicious entrypoint. Resolves a
# symlinked bin/vibe and re-confirms the real target is root-owned and under the
# allowed roots too.
assert_safe_entrypoint() {
  dir="$1"                       # already-canonical site dir (SITE_DIR_REAL)
  entry="$dir/bin/vibe"
  [ -e "$entry" ] || die "site has no bin/vibe entrypoint"
  # The site dir itself must be root-owned + not group/other-writable, else the
  # bin/ subtree (or bin/vibe) could be swapped out underneath us.
  assert_root_owned "$dir" "site dir"
  assert_root_owned "$dir/bin" "site bin dir"
  assert_root_owned "$entry" "site bin/vibe"
  # If bin/vibe is a symlink, resolve it and re-validate the real file: it must
  # also be root-owned, not group/other-writable, and live under the roots.
  if [ -L "$entry" ]; then
    real_entry_dir="$(canonical_dir "$(dirname -- "$entry")")"
    target_name="$(readlink -- "$entry")"
    case "$target_name" in
      /*) resolved="$target_name" ;;
      *)  resolved="$real_entry_dir/$target_name" ;;
    esac
    resolved_dir="$(canonical_dir "$(dirname -- "$resolved")")"
    [ -n "$resolved_dir" ] || die "bin/vibe symlink target is missing"
    real_target="$resolved_dir/$(basename -- "$resolved")"
    [ -f "$real_target" ] || die "bin/vibe symlink target is not a regular file"
    under_allowed_root "$real_target" \
      || die "bin/vibe symlink target is outside the allowed roots"
    assert_root_owned "$resolved_dir" "bin/vibe symlink target dir"
    assert_root_owned "$real_target" "bin/vibe symlink target"
  fi
  [ -x "$entry" ] || die "site bin/vibe is not executable"
}

# --- Op + argument allowlist. Re-validated HERE at the root boundary so a
# compromised panel cannot reach the full bin/vibe surface (restore, harden,
# wp eval-file, db, …) by passing an op the panel-side would have rejected.
# This set mirrors the first argv token of EVERY exec.ts VIBE_OPS entry
# (spec.argv[0]); keep it in sync with control-panel exec.ts VIBE_OPS.
#   smoke doctor-runtime monitor perf-report perf-measure perf-apply security-status compose env
#   backups backup backup-config-apply backup-test backup-verify
#   backup-list-contents backup-restore-item
#   backup-schedule-apply auto-update-schedule-apply monitor-schedule-apply schedule-status site-config-apply
#   caddy-www-apply notify-config-apply notify-test smtp-config-apply smtp-test
#   logs-recent logs up down restart nginx-recreate cache-flush restore refresh-from-prod
#   promote-files-to-prod harden wp insights vuln-feed-fetch
OP_ALLOWLIST="smoke doctor-runtime monitor perf-report perf-measure perf-apply security-status compose env backups backup backup-config-apply backup-test backup-verify backup-list-contents backup-restore-item backup-schedule-apply auto-update-schedule-apply monitor-schedule-apply schedule-status site-config-apply caddy-www-apply notify-config-apply notify-test smtp-config-apply smtp-test logs-recent logs up down restart nginx-recreate cache-flush restore refresh-from-prod promote-files-to-prod harden wp insights vuln-feed-fetch"

# Free-form (caller-supplied) args reach only a few ops: restore/backup-verify
# take a backup path; the schedule/notify/site/backup-config-apply ops and
# caddy-www-apply take a single keyword token (on|off|daily|weekly); the rest
# take fixed in-image argv we allowlist below.
# Anything beginning with '-' is allowed only if it is a known panel flag — this
# is exactly the set of flags exec.ts VIBE_OPS bake into their argv (plus --yes):
#   monitor --json --no-notify | perf-report --json | backup --local-only | *--yes
#   promote-files-to-prod --no-backup (the panel's "Push to live" job owns its
#   own pre-promote prod snapshot, so the promote script must not take a second one)
FLAG_ALLOWLIST="--local-only --yes --json --no-notify --no-backup"
# The `logs`/`logs-recent` ops are special-cased: their args are a fixed
# service enum (all nginx wordpress cron db redis) + a fixed tail enum
# (100 200 500 2000), validated by validate_logs_args — NOT the generic
# validate_arg path (which would allow any metachar-free token as a service).

validate_op() {
  op="$1"
  for allowed in $OP_ALLOWLIST; do
    [ "$op" = "$allowed" ] && return 0
  done
  die "op not allowed: $op"
}

# Validate a single non-op argument. Flags must be in the allowlist; non-flag
# args must not contain shell metacharacters, '..', or whitespace. We do NOT
# reject a leading '/' (restore/backup-verify take absolute backup paths), but
# such paths still go through the metachar + '..' guard.
validate_arg() {
  arg="$1"
  case "$arg" in
    -*)
      for allowed in $FLAG_ALLOWLIST; do
        [ "$arg" = "$allowed" ] && return 0
      done
      die "flag not allowed: $arg"
      ;;
  esac
  case "$arg" in
    *..*) die "argument contains '..': $arg" ;;
    *[\;\|\&\$\`\<\>\(\)\{\}\*\?\!]*) die "argument contains shell metacharacters: $arg" ;;
    *' '*) die "argument contains whitespace: $arg" ;;
  esac
}

# Validate a backup path argument for the backup-list-contents / backup-restore-item
# ops. STRICTER than validate_arg: the path must, after the generic metachar/'..'
# guard, resolve to an EXISTING directory CONFINED under the site's backups root
# ($SITE_DIR_REAL/backups). This closes the gap where a metachar-free path could
# point anywhere readable. Accepts both relative (`backups/<env>/<ts>`, resolved
# against the site dir) and absolute (under $SITE_DIR_REAL/backups) forms.
# NOTE: this is applied ONLY to the two new ops; restore/backup-verify keep their
# existing generic validate_arg behavior (see the OPEN DECISION in the PR notes).
validate_backup_path() {
  bp="$1"
  validate_arg "$bp"                       # metachar/'..'/whitespace guard first
  [ -n "${SITE_DIR_REAL:-}" ] || die "backup path validated before site dir"
  allowed_root="$(canonical_dir "$SITE_DIR_REAL/backups")"
  [ -n "$allowed_root" ] || die "site has no backups directory"
  # Resolve the candidate. A relative path is taken against the site dir (the
  # panel always sends `backups/<env>/<ts>`); an absolute one is used as-is.
  case "$bp" in
    /*) cand_dir="$bp" ;;
    *)  cand_dir="$SITE_DIR_REAL/$bp" ;;
  esac
  real_cand="$(canonical_dir "$cand_dir")"
  [ -n "$real_cand" ] || die "backup path does not exist or is not a directory"
  case "$real_cand" in
    "$allowed_root"/*) : ;;
    *) die "backup path is outside the site backups root: $bp" ;;
  esac
}

# Validate a single restore-item NAME per its kind. table -> ^[A-Za-z0-9_]{1,64}$;
# file -> a safe relative path (validate_arg's metachar/'..'/whitespace guard,
# plus no leading '/' and no leading '-'). Re-validated HERE at the root boundary
# even though the script re-checks too (defense-in-depth).
validate_item_name() {
  kind="$1"
  iname="$2"
  case "$kind" in
    table)
      case "$iname" in
        ''|*[!A-Za-z0-9_]*) die "table name fails ^[A-Za-z0-9_]{1,64}$: $iname" ;;
      esac
      [ "${#iname}" -le 64 ] || die "table name too long: $iname"
      ;;
    file)
      case "$iname" in
        '') die "file name is empty" ;;
        /*) die "file name must be a relative path: $iname" ;;
        -*) die "file name must not start with '-': $iname" ;;
      esac
      validate_arg "$iname"                # metachar/'..'/whitespace guard
      ;;
    *)
      die "restore-item kind must be file|table: $kind"
      ;;
  esac
}

# `wp` is special: re-validate the subcommand at the root boundary. Accepts the
# pre-existing fixed forms byte-for-byte PLUS the feature #4 per-item forms
# (structured verb × slug-regex). NEVER reachable: eval / eval-file / db / shell /
# config / search-replace / install / etc. $@ here is the args AFTER the `wp` op.
validate_wp_slug() {
  slug="$1"
  case "$slug" in
    *://*) die "wp slug must not be a URL" ;;
    ''|-*) die "wp slug empty or leading-hyphen: $slug" ;;
    *[!a-z0-9-]*) die "wp slug fails regex: $slug" ;;
  esac
  [ "${#slug}" -le 63 ] || die "wp slug too long: $slug"
}

validate_wp_version_flag() {
  case "$1" in
    --version=*) val="${1#--version=}" ;;
    *) die "only --version= flag allowed here: $1" ;;
  esac
  # semver-ish: 1.2 | 1.2.3 | 1.2.3-beta.1 ; reject anything with extra chars.
  case "$val" in
    *[!0-9.a-zA-Z-]*) die "--version= value has illegal chars: $val" ;;
    [0-9]*.[0-9]*) : ;;
    *) die "--version= value is not a version: $val" ;;
  esac
}

validate_wp_args() {
  # Fast-path: the four pre-existing FIXED forms keep working byte-for-byte.
  joined="$*"
  case "$joined" in
    "core update") return 0 ;;
    "plugin update --all") return 0 ;;
    "plugin list --update=available --format=json") return 0 ;;
    "cron event run vibe_insights_collect_cron") return 0 ;;
  esac
  # Structured per-item forms (feature #4). `cron` is NOT a general namespace:
  # only the one fixed cron form above is allowed; anything else dies below.
  namespace="${1:-}"; verb="${2:-}"
  case "$namespace" in
    plugin|theme|core) : ;;
    *) die "wp namespace not allowed: $namespace" ;;
  esac
  # Note: there is intentionally NO "theme deactivate" — WordPress has no
  # wp-cli theme-deactivate (a site always has one active theme), so the panel
  # never sends it. "core version" is also intentionally omitted: the panel reads
  # the core version from the insights drop-file, not via wp-cli.
  case "$namespace $verb" in
    "plugin activate"|"plugin deactivate"|"plugin update"|"plugin delete"|\
    "plugin auto-updates"|\
    "theme activate"|"theme update"|"theme delete"|"theme auto-updates"|\
    "core update") : ;;
    *) die "wp subcommand not allowed: wp $namespace $verb" ;;
  esac
  # core update [--version=X] — no slug.
  if [ "$namespace $verb" = "core update" ]; then
    [ "$#" -le 3 ] || die "wp core update takes at most one --version= flag"
    [ "$#" -eq 3 ] && validate_wp_version_flag "$3"
    return 0
  fi
  # auto-updates: `<ns> auto-updates <enable|disable> <slug>` (subverb THEN slug).
  if [ "$verb" = "auto-updates" ]; then
    subverb="${3:-}"; slug="${4:-}"
    case "$subverb" in enable|disable) : ;; *) die "auto-updates needs enable|disable" ;; esac
    validate_wp_slug "$slug"
    [ "$#" -eq 4 ] || die "wp auto-updates takes exactly 4 args"
    return 0
  fi
  # activate/deactivate/update/delete <slug> [--version=X (update only)]
  slug="${3:-}"
  validate_wp_slug "$slug"
  if [ "$#" -eq 4 ]; then
    [ "$verb" = "update" ] || die "$namespace $verb takes no flags"
    validate_wp_version_flag "$4"
  elif [ "$#" -gt 4 ]; then
    die "too many arguments for wp $namespace $verb"
  fi
  return 0
}

# `compose` is special too: the panel's only compose op is the read-only
# `compose ps --format json` (psJson). Reject any other compose surface
# (up/down/exec/run/cp/… as a compose op would bypass the dedicated ops).
validate_compose_args() {
  joined="$*"
  case "$joined" in
    "ps --format json") return 0 ;;
    *) die "compose subcommand not allowed: compose $joined" ;;
  esac
}

# `env` is special: bin/vibe's `env` op prints the RAW value of ANY env-file key
# (DB/Redis passwords, WP salts, R2/Anthropic secrets, the admin password, …),
# so validate_arg's "no shell metacharacters" check is NOT enough — every secret
# key name passes it. Restrict the op to EXACTLY ONE key, and that key must be in
# a FIXED non-secret allowlist. This MUST mirror NON_SECRET_KEYS in the panel's
# control-panel/packages/api/src/routers/devinfo.ts — the only place the panel
# uses the env op (the Developer details panel reads exactly these keys). $@ here
# is the args AFTER the `env` op token.
ENV_KEY_ALLOWLIST="WP_HOME COMPOSE_PROJECT_NAME WP_ENVIRONMENT_TYPE WORDPRESS_IMAGE WP_MEMORY_LIMIT WP_MAX_MEMORY_LIMIT WP_CACHE WP_DEBUG_LOG HTTP_PORT"
validate_env_key() {
  [ "$#" -eq 1 ] || die "env op takes exactly one key argument"
  key="$1"
  for allowed in $ENV_KEY_ALLOWLIST; do
    [ "$key" = "$allowed" ] && return 0
  done
  die "env key not allowed: $key"
}

# `logs` / `logs-recent` take up to two positional args: a service from the
# fixed compose-service enum and a tail depth from the fixed enum. Re-validated
# HERE so a compromised panel cannot tail an arbitrary container or pass an
# unbounded --tail. Mirrors bin/vibe _validate_logs_args and the router enums.
LOG_SERVICE_ENUM="all nginx wordpress cron db redis"
LOG_TAIL_ENUM="100 200 500 2000"
validate_logs_args() {
  [ "$#" -le 2 ] || die "logs op takes at most 2 args (service, tail)"
  if [ "$#" -ge 1 ]; then
    _ok=0
    for s in $LOG_SERVICE_ENUM; do [ "$1" = "$s" ] && _ok=1 && break; done
    [ "$_ok" = 1 ] || die "logs service not allowed: $1"
  fi
  if [ "$#" -ge 2 ]; then
    _ok=0
    for t in $LOG_TAIL_ENUM; do [ "$2" = "$t" ] && _ok=1 && break; done
    [ "$_ok" = 1 ] || die "logs tail not allowed: $2"
  fi
}

# `shared-db` op allowlist — re-validated HERE at the root boundary (mirrors the
# wrapper subcommand surface in exec.ts wrapSharedDbArgv). Defined above the
# dispatch guard so unit tests can source the wrapper as a lib and exercise it
# without Docker. The slug re-validation uses the lib's own sdb_validate_slug
# (SF-5), not a re-typed regex.
SHARED_DB_OP_ALLOWLIST="init status provision deprovision backup rotate-root"
validate_shared_db_op() {
  op="$1"
  for allowed in $SHARED_DB_OP_ALLOWLIST; do
    [ "$op" = "$allowed" ] && return 0
  done
  die "shared-db op not allowed: $op"
}

# --- panel-domain: STRICT hostname re-validation at the root boundary. This is
# the LOAD-BEARING copy (the panel is the untrusted caller; bin/panel-domain-apply
# re-validates too as defense in depth). The value lands in a Caddy config file
# AND an env file, so injection is the top risk: a POSITIVE allowlist (`case
# *[!a-z0-9.-]*` die) rejects every shell/Caddy metachar, '/', and uppercase. The
# value must be a valid FQDN of >=2 labels, each 1-63 chars with no leading/
# trailing dash, total <=253, no '..', and not a reserved/test name. Defined above
# the dispatch guard so unit tests can source the wrapper as a lib and exercise it.
validate_panel_domain() {
  d="$1"
  [ -n "$d" ] || die "panel domain is empty"
  [ "${#d}" -le 253 ] || die "panel domain too long (>253): $d"
  # POSITIVE allowlist: ONLY lowercase letters, digits, dot, hyphen survive.
  case "$d" in
    *[!a-z0-9.-]*) die "panel domain has illegal characters (only a-z 0-9 . - allowed): $d" ;;
  esac
  case "$d" in
    .*|*.) die "panel domain must not start or end with a dot: $d" ;;
    *..*) die "panel domain must not contain '..': $d" ;;
    -*|*-) die "panel domain must not start or end with a dash: $d" ;;
    *.*) : ;;  # require at least one dot (>=2 labels)
    *) die "panel domain must be a fully-qualified name with a dot: $d" ;;
  esac
  oifs="$IFS"
  IFS=.
  for label in $d; do
    [ -n "$label" ] || { IFS="$oifs"; die "empty label in panel domain: $d"; }
    [ "${#label}" -le 63 ] || { IFS="$oifs"; die "panel domain label longer than 63 chars: $label"; }
    case "$label" in
      -*|*-) IFS="$oifs"; die "panel domain label starts or ends with a dash: $label" ;;
    esac
  done
  IFS="$oifs"
  case "$d" in
    localhost|*.localhost|*.test|*.invalid|*.example|*.example.com|*.example.net|*.example.org)
      die "panel domain uses a reserved/test name: $d" ;;
  esac
}

# --- siteinfo: scan roots, print ONLY non-secret fields as TAB-separated rows.
# Columns: installDir  slug  domain  prodPort  stagePort  hasStaging  stagingDomain
# slug          = COMPOSE_PROJECT_NAME minus the vibe-wp- prefix and -prod/-stage suffix
# domain        = host part of prod WP_HOME
# *Port         = numeric tail of HTTP_PORT (e.g. 127.0.0.1:18000 -> 18000)
# stagingDomain = host part of stage WP_HOME ("" when no staging)
# We read prod.env / stage.env which are 0600 root-only (they hold secrets) and
# deliberately surface NONE of those secret keys — only these non-secret fields
# (install dir, slug, the public domains, the published HTTP ports, staging flag).
env_value() {
  # Read a single KEY's value from an env file without sourcing it (so no env
  # file content can execute). Strips surrounding quotes. Empty if absent.
  file="$1"
  key="$2"
  [ -f "$file" ] || { echo ""; return 0; }
  line="$(grep -m1 "^${key}=" "$file" 2>/dev/null || true)"
  val="${line#*=}"
  # strip matching surrounding single or double quotes
  case "$val" in
    \"*\") val="${val#\"}"; val="${val%\"}" ;;
    \'*\') val="${val#\'}"; val="${val%\'}" ;;
  esac
  echo "$val"
}

host_of() {
  # Extract the hostname from a URL like https://example.com/path -> example.com
  url="$1"
  [ -n "$url" ] || { echo ""; return 0; }
  # drop scheme://, then everything from the first / or : onwards
  rest="${url#*://}"
  rest="${rest%%/*}"
  rest="${rest%%:*}"
  echo "$rest"
}

port_of() {
  # Numeric tail of HTTP_PORT (after the last ':'); empty if not a positive int.
  raw="$1"
  [ -n "$raw" ] || { echo ""; return 0; }
  num="${raw##*:}"
  case "$num" in
    ''|*[!0-9]*) echo "" ;;
    *) [ "$num" -gt 0 ] 2>/dev/null && echo "$num" || echo "" ;;
  esac
}

slug_of() {
  # vibe-wp-<slug>-prod / vibe-wp-<slug>-stage -> <slug>; fall back to dir tail.
  project="$1"
  fallback="$2"
  [ -n "$project" ] || { echo "$fallback"; return 0; }
  s="${project#vibe-wp-}"
  s="${s%-prod}"
  s="${s%-stage}"
  [ -n "$s" ] && echo "$s" || echo "$fallback"
}

siteinfo() {
  IFS=:
  for root in $PANEL_SITES_ROOTS; do
    [ -n "$root" ] || continue
    [ -d "$root" ] || continue
    # Find site install dirs (those containing bin/vibe) up to a small depth.
    find "$root" -maxdepth 4 -type f -path '*/bin/vibe' 2>/dev/null
  done | while IFS= read -r vibebin; do
    dir="${vibebin%/bin/vibe}"
    prod="$dir/env/prod.env"
    stage="$dir/env/stage.env"
    home="$(env_value "$prod" WP_HOME)"
    [ -n "$home" ] || home="$(env_value "$stage" WP_HOME)"
    [ -n "$home" ] || continue
    fallback="${dir##*/}"
    slug="$(slug_of "$(env_value "$prod" COMPOSE_PROJECT_NAME)" "$fallback")"
    domain="$(host_of "$home")"
    prod_port="$(port_of "$(env_value "$prod" HTTP_PORT)")"
    stage_port="$(port_of "$(env_value "$stage" HTTP_PORT)")"
    stage_home="$(env_value "$stage" WP_HOME)"
    if [ -n "$stage_home" ]; then
      has_staging=1
      staging_domain="$(host_of "$stage_home")"
    else
      has_staging=0
      staging_domain=""
    fi
    # TAB-separated; non-secret fields ONLY.
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$dir" "$slug" "$domain" "$prod_port" "$stage_port" "$has_staging" "$staging_domain"
  done
  unset IFS
}

# When sourced as a library (unit tests source this file to call the validate_*
# functions directly), expose the functions but do NOT dispatch. Normal execution
# leaves VIBE_PANEL_RUN_LIB unset, so the gate below runs exactly as before.
if [ "${VIBE_PANEL_RUN_LIB:-}" != "1" ]; then
sub="${1:-}"
[ -n "$sub" ] || die "missing subcommand"
shift || true

case "$sub" in
  vibe)
    # vibe <siteDir> <env> <op> [args...]
    [ $# -ge 3 ] || die "usage: vibe <siteDir> <env> <op> [args...]"
    site_dir="$1"; shift
    env_tok="$1"; shift
    op="$1"; shift
    validate_site_dir "$site_dir"          # absolute, under roots, no '..'
    validate_env "$env_tok"                # in {local,stage,prod,external}
    assert_safe_entrypoint "$SITE_DIR_REAL" # root-owned, not world-writable
    validate_op "$op"                      # op in the fixed allowlist
    # Argument re-validation at the root boundary (do NOT trust the caller).
    case "$op" in
      wp)      validate_wp_args "$@" ;;     # 4 fixed forms + per-item plugin/theme/core (slug-validated)
      compose) validate_compose_args "$@" ;; # only `compose ps --format json`
      env)     validate_env_key "$@" ;;     # exactly one key, non-secret allowlist
      logs|logs-recent) validate_logs_args "$@" ;; # fixed service + tail enums
      auto-update-schedule-apply)          # exactly one cadence keyword
        [ "$#" -eq 1 ] || die "auto-update-schedule-apply takes one keyword"
        case "$1" in off|weekly|daily) : ;; *) die "schedule must be off|weekly|daily" ;; esac
        ;;
      backup-list-contents)                # exactly one backup path, confined
        [ "$#" -eq 1 ] || die "backup-list-contents takes exactly one backup path"
        validate_backup_path "$1"
        ;;
      backup-restore-item)                 # <backupPath> <file|table> <name>
        [ "$#" -eq 3 ] || die "backup-restore-item takes exactly 3 args"
        validate_backup_path "$1"
        case "$2" in file|table) : ;; *) die "restore-item kind must be file|table: $2" ;; esac
        validate_item_name "$2" "$3"
        ;;
      vuln-feed-fetch)                     # ZERO argv args — slugs arrive on STDIN
        [ "$#" -eq 0 ] || die "vuln-feed-fetch takes no arguments (slugs are stdin-only)"
        ;;
      perf-apply)                          # mutating perf-tuning writer (feature #5)
        # Only `--rollback` or NO args may reach the writer on argv. The tunable
        # VALUES never travel on argv: they arrive as VIBE_PERF_* env vars (kept
        # in panel_env_keep) and the writer re-asserts the FIXED PERF allowlist +
        # the reserved<=85% RAM cap at its own root boundary. So even a compromised
        # panel cannot pass an arbitrary key/value here — only the mode flag.
        if [ "$#" -eq 0 ]; then
          : # forward apply (values via env)
        elif [ "$#" -eq 1 ] && [ "$1" = "--rollback" ]; then
          : # restore from the env/<env>.perf.bak snapshot
        else
          die "perf-apply takes only --rollback or no args"
        fi
        ;;
      *)
        for a in "$@"; do
          validate_arg "$a"
        done
        ;;
    esac
    # Reconstruct and exec the site's own (verified) entrypoint.
    exec "$SITE_DIR_REAL/bin/vibe" "$env_tok" "$op" "$@"
    ;;
  installer)
    # installer --headless-json  (NOTHING else is permitted)
    [ $# -eq 1 ] || die "installer takes exactly one arg"
    [ "$1" = "--headless-json" ] || die "installer arg must be --headless-json"
    [ -x "$PANEL_INSTALLER_BIN" ] || die "installer binary not executable"
    # Same root-exec hygiene as the site entrypoint: refuse to run a non-root or
    # group/other-writable installer binary (else a panel that could rewrite it
    # would get root). The binary is installed root-owned by bin/panel.
    assert_root_owned "$PANEL_INSTALLER_BIN" "installer binary"
    exec "$PANEL_INSTALLER_BIN" --headless-json
    ;;
  siteinfo)
    [ $# -eq 0 ] || die "siteinfo takes no arguments"
    siteinfo
    ;;
  support-bundle)
    # support-bundle  (zero args) — emit a REDACTED gzip tar to stdout.
    # The collector lives in the deployed source repo (fixed at this boundary).
    # We assert it (and the bin dir) is a root-owned, non-writable, executable
    # regular file before exec'ing it as root: a panel that could write into the
    # repo could otherwise plant a malicious collector and get root. The script
    # itself only reads NON-SECRET data and redacts every member before tar, but
    # the exec-target hygiene is the load-bearing root-boundary guard here.
    [ $# -eq 0 ] || die "support-bundle takes no arguments"
    sb_bin="$PANEL_HOST_DIR/bin"
    assert_root_owned "$sb_bin" "support-bundle bin dir"
    sb_script="$sb_bin/support-bundle"
    [ -f "$sb_script" ] || die "support-bundle script missing: $sb_script"
    assert_root_owned "$sb_script" "support-bundle script"
    [ -x "$sb_script" ] || die "support-bundle script not executable: $sb_script"
    # Pass the trusted roots/host-dir through so the collector discovers sites and
    # resolves git/doctor from the same fixed locations this boundary uses. exec
    # so the collector's stdout (the archive) flows straight to the caller.
    PANEL_SITES_ROOTS="$PANEL_SITES_ROOTS" \
    PANEL_HOST_DIR="$PANEL_HOST_DIR" \
      exec "$sb_script"
    ;;
  panel-update)
    # panel-update  (zero args) — update the panel + stack from the GUI.
    # STRICTLY allowlisted to EXACTLY `bin/panel update`: no other bin/panel
    # subcommand (install/uninstall/reset-password) is reachable from here.
    [ $# -eq 0 ] || die "panel-update takes no arguments"
    pu_panel="$PANEL_HOST_DIR/bin/panel"
    assert_root_owned "$PANEL_HOST_DIR/bin" "panel bin dir"
    [ -f "$pu_panel" ] || die "bin/panel missing: $pu_panel"
    assert_root_owned "$pu_panel" "bin/panel"
    [ -x "$pu_panel" ] || die "bin/panel is not executable: $pu_panel"
    # CRITICAL: `bin/panel update` ends in `systemctl restart vibe-wp-panel`,
    # which SIGTERMs the panel server (our parent). If we ran the updater in the
    # panel's process tree the restart would kill it mid-flight and leave a
    # half-updated checkout. Run it in a TRANSIENT systemd scope/unit so it is
    # reparented to systemd and survives the panel restart; its output goes to
    # the journal, which the panel tails back via `journalctl -u <unit> -f`.
    pu_unit="vibe-wp-panel-update"
    if command -v systemd-run >/dev/null 2>&1; then
      # --collect drops the transient unit once it exits so a later run can reuse
      # the name. A fresh run first resets any lingering failed unit of that name.
      systemctl reset-failed "$pu_unit" >/dev/null 2>&1 || true
      exec systemd-run --collect --unit="$pu_unit" \
        --property=Description="Vibe WP panel + stack update" \
        --setenv=PANEL_HOST_DIR="$PANEL_HOST_DIR" \
        "$pu_panel" update
    fi
    # Fallback (no systemd-run): detach via setsid + nohup so the SIGTERM the
    # panel restart sends to its own process group does not reach the updater.
    exec setsid sh -c 'exec nohup "$0" update >/dev/null 2>&1' "$pu_panel"
    ;;
  panel-domain)
    # panel-domain <domain> — ADD a custom domain to the control-panel Caddy site
    # ALONGSIDE the magic-DNS host (additive; the magic-DNS host is NEVER removed)
    # and add it to the panel's trusted origins. EXACTLY one arg; the domain is
    # STRICTLY re-validated HERE at the root boundary (validate_panel_domain — do
    # NOT trust the panel) before anything is touched. The domain travels as a
    # single argv element (never a shell string).
    [ $# -eq 1 ] || die "panel-domain takes exactly one domain argument"
    pd_domain="$1"
    validate_panel_domain "$pd_domain"
    pd_bin="$PANEL_HOST_DIR/bin"
    assert_root_owned "$pd_bin" "panel-domain bin dir"
    pd_script="$pd_bin/panel-domain-apply"
    [ -f "$pd_script" ] || die "panel-domain-apply missing: $pd_script"
    assert_root_owned "$pd_script" "panel-domain-apply script"
    [ -x "$pd_script" ] || die "panel-domain-apply is not executable: $pd_script"
    # CRITICAL: the script ends in `systemctl restart vibe-wp-panel`, which SIGTERMs
    # the panel server (our caller's parent). Run it in a TRANSIENT systemd unit so
    # it is reparented to systemd and survives the panel restart; the domain is
    # passed as a single argv element. Output goes to the journal the panel can tail.
    pd_unit="vibe-wp-panel-domain"
    if command -v systemd-run >/dev/null 2>&1; then
      systemctl reset-failed "$pd_unit" >/dev/null 2>&1 || true
      exec systemd-run --collect --unit="$pd_unit" \
        --property=Description="Vibe WP panel custom-domain apply" \
        --setenv=PANEL_HOST_DIR="$PANEL_HOST_DIR" \
        "$pd_script" "$pd_domain"
    fi
    # Fallback (no systemd-run): detach via setsid + nohup so the SIGTERM the panel
    # restart sends to its own process group does not reach the apply op.
    exec setsid sh -c 'exec nohup "$0" "$1" >/dev/null 2>&1' "$pd_script" "$pd_domain"
    ;;
  shared-db)
    # shared-db <op> [slug]  — host-level ops for the ONE shared MariaDB project.
    #   op ∈ {init, status, provision, deprovision, backup}
    #   provision/deprovision take EXACTLY one slug (re-validated below); the
    #   rest take none. These are NOT per-site ops (no site dir / no bin/vibe);
    #   they run the deployed repo's bin/shared-db-* / bin/db-* scripts as root
    #   against the shared container. The shared-db state dir + its 0600 env file
    #   are asserted root-owned before any op other than init.
    sdb_op="${1:-}"; shift || true
    validate_shared_db_op "$sdb_op"

    # Scripts live in the deployed source repo (fixed at this boundary).
    sdb_bin="$PANEL_HOST_DIR/bin"
    assert_root_owned "$sdb_bin" "shared-db bin dir"

    # State dir + env-file hygiene (everything but init, which creates them).
    sdb_state_dir="${SHARED_DB_DIR:-/opt/vibe-wp-shared-db}"
    if [ "$sdb_op" != "init" ]; then
      [ -d "$sdb_state_dir" ] || die "shared-db not initialized ($sdb_state_dir missing)"
      assert_root_owned "$sdb_state_dir" "shared-db state dir"
      sdb_envf="$sdb_state_dir/env/shared-db.env"
      [ -f "$sdb_envf" ] || die "shared-db env file missing"
      assert_root_owned "$sdb_envf" "shared-db env file"
      # Holds the root password — must have NO group/other access bits at all.
      if [ -n "$(find "$sdb_envf" -prune -perm /077 2>/dev/null)" ]; then
        die "shared-db env file is group/other-accessible (refusing)"
      fi
    fi

    # Map op -> script + enforce arity (SF-6).
    case "$sdb_op" in
      init)        sdb_script="$sdb_bin/shared-db-init";        [ "$#" -eq 0 ] || die "shared-db init takes no args" ;;
      status)      sdb_script="$sdb_bin/shared-db-status";      [ "$#" -eq 0 ] || die "shared-db status takes no args" ;;
      backup)      sdb_script="$sdb_bin/backup-shared-db";      [ "$#" -eq 0 ] || die "shared-db backup takes no args" ;;
      rotate-root) sdb_script="$sdb_bin/shared-db-rotate-root"; [ "$#" -eq 0 ] || die "shared-db rotate-root takes no args" ;;
      provision)   sdb_script="$sdb_bin/db-provision";     [ "$#" -eq 1 ] || die "shared-db provision takes exactly one slug" ;;
      deprovision) sdb_script="$sdb_bin/db-deprovision";   [ "$#" -eq 1 ] || die "shared-db deprovision takes exactly one slug" ;;
    esac

    # SF-5: defense-in-depth slug re-validation using the lib's OWN validator (no
    # re-typed regex). Sourcing executes the lib as root, so assert it is a
    # root-owned, non-writable file first. sdb_validate_slug `die`s on any invalid
    # slug; its echoed identifier is discarded.
    if [ "$sdb_op" = "provision" ] || [ "$sdb_op" = "deprovision" ]; then
      sdb_lib="$sdb_bin/lib/shared-db.sh"
      [ -f "$sdb_lib" ] || die "shared-db lib missing: $sdb_lib"
      assert_root_owned "$sdb_lib" "shared-db lib"
      # shellcheck disable=SC1090
      . "$sdb_lib"
      sdb_validate_slug "$1" >/dev/null
    fi

    # The target script must be a root-owned, non-writable, executable regular file.
    [ -f "$sdb_script" ] || die "shared-db script missing: $sdb_script"
    assert_root_owned "$sdb_script" "shared-db script"
    [ -x "$sdb_script" ] || die "shared-db script not executable: $sdb_script"
    exec "$sdb_script" "$@"
    ;;
  *)
    die "unknown subcommand: $sub"
    ;;
esac
fi
