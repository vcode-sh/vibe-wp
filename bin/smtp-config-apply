#!/usr/bin/env sh
set -eu
umask 077
# Persist the SMTP relay configuration into the selected environment's env file.
#
# The control panel injects the resolved config as environment variables (from
# its SQLite store) and runs this command. We write those values into the env
# file so that BOTH the panel AND the WordPress mailer — which reads the env
# file directly — see the same SMTP settings.
#
# Only the managed SMTP_* keys are touched; every other line is preserved
# verbatim. Secrets are never printed.

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"

vibe_require_env_file
file="${VIBE_ENV_FILE}"

# All edits are staged on a working copy that inherits the env file's mode and
# owner (cp -p), then swapped in with a single atomic rename. The real env file
# — which also holds the DB password and WP salts — is therefore never observed
# truncated or half-written, and never has its 0600 permissions widened.
work="${file}.vibe-apply.$$"
line="${work}.line"
trap 'rm -f "${work}" "${line}"' EXIT INT TERM
if [ -f "${file}" ]; then
  cp -p "${file}" "${work}"
else
  : > "${work}"
fi

# Replace `KEY=...` in place on the working copy, or append it when absent.
# Writes through the working copy's existing inode so its mode is preserved.
env_upsert() {
  key="$1"
  val="$2"
  # Env files are sourced with `set -a; . file`; a newline would split the value
  # into a second shell statement, so strip CR/LF defensively.
  val="$(printf '%s' "${val}" | tr -d '\r\n')"
  found=0
  {
    while IFS= read -r entry || [ -n "${entry}" ]; do
      case "${entry}" in
        "${key}="*)
          printf '%s=%s\n' "${key}" "${val}"
          found=1
          ;;
        *) printf '%s\n' "${entry}" ;;
      esac
    done < "${work}"
    [ "${found}" -eq 1 ] || printf '%s=%s\n' "${key}" "${val}"
  } > "${line}"
  cat "${line}" > "${work}"
}

# SMTP_MODE is authoritative on every apply (defaults to off).
env_upsert SMTP_MODE "${SMTP_MODE:-off}"

# The credential/config keys are only rewritten when the panel supplied them, so
# a "preserve existing password" save (which omits SMTP_PASSWORD) never blanks
# it; clearing a value is done by sending an empty string (upserts "").
for key in \
  SMTP_HOST \
  SMTP_PORT \
  SMTP_SECURE \
  SMTP_AUTH \
  SMTP_USER \
  SMTP_PASSWORD \
  SMTP_FROM \
  SMTP_FROM_NAME; do
  eval "val=\${${key}:-__VIBE_UNSET__}"
  [ "${val}" = "__VIBE_UNSET__" ] && continue
  env_upsert "${key}" "${val}"
done

# Atomic, same-filesystem swap into place.
mv -f "${work}" "${file}"
echo "SMTP configuration applied to ${file}"
