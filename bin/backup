#!/usr/bin/env sh
set -eu

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"
. "${VIBE_BIN_DIR}/lib/backup.sh"

label=""
local_only=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --label)
      label="${2:-}"
      shift 2
      ;;
    --local-only)
      # Per-run override: keep the backup on disk even when R2 is enabled.
      # This is a CLI flag (not an env var) so it cannot be clobbered by the
      # env file that vibe_load_env sources with `set -a`.
      local_only=1
      shift
      ;;
    -h|--help)
      cat <<'USAGE'
Usage:
  ./bin/backup [--label LABEL] [--local-only]

Creates a backup for the selected VIBE_ENV. The archive is written under
VIBE_BACKUP_DIR (default backups/<env>/) in a <timestamp>[-label]/ directory,
then, when VIBE_BACKUP_R2_ENABLED=1, uploaded to Cloudflare R2 via rclone.
Old local and remote backups beyond VIBE_BACKUP_RETENTION are pruned.

--local-only keeps this one backup on disk only (no off-site upload or remote
prune), regardless of VIBE_BACKUP_R2_ENABLED.
USAGE
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

timestamp="$(date -u +"%Y%m%dT%H%M%SZ")"
safe_env="$(printf '%s' "${VIBE_ENV}" | tr -c 'A-Za-z0-9_.-' '-')"
safe_label="$(printf '%s' "${label}" | tr -c 'A-Za-z0-9_.-' '-')"

backup_dir_root="$(backup_root)"
if [ -n "${safe_label}" ]; then
  target="${backup_dir_root}/${timestamp}-${safe_label}"
else
  target="${backup_dir_root}/${timestamp}"
fi

mkdir -p "${target}"

vibe_require_env_file
services="wordpress"
if vibe_compose_service_exists db; then
  services="db ${services}"
fi
if vibe_compose_service_exists redis; then
  services="redis ${services}"
fi
# shellcheck disable=SC2086
vibe_compose up -d ${services} >/dev/null

echo "Dumping MariaDB..."
database_sql="${target}/database.sql"
if vibe_compose_service_exists db; then
  vibe_compose exec -T db sh -c 'mariadb-dump --single-transaction --routines --triggers -u"$MARIADB_USER" -p"$MARIADB_PASSWORD" "$MARIADB_DATABASE"' > "${database_sql}"
else
  vibe_wp_stdin db export - --single-transaction --routines --triggers > "${database_sql}"
fi
gzip -f "${database_sql}"

echo "Archiving wp-content..."
vibe_compose exec -T wordpress tar -czf - -C /var/www/html/wp-content . > "${target}/wp-content.tar.gz"

wp_home="$(vibe_env_value WP_HOME 2>/dev/null || true)"
project_name="$(vibe_env_value COMPOSE_PROJECT_NAME 2>/dev/null || true)"

cat > "${target}/manifest.txt" <<EOF
created_at=${timestamp}
environment=${VIBE_ENV}
compose_project_name=${project_name}
wp_home=${wp_home}
database=database.sql.gz
wp_content=wp-content.tar.gz
EOF

echo "Backup written to ${target}"

retention="$(vibe_env_value VIBE_BACKUP_RETENTION 2>/dev/null || true)"

if [ "${local_only}" -eq 1 ]; then
  echo "Local-only backup: skipping off-server upload."
elif backup_remote_enabled; then
  backup_upload "${target}"
  echo "Backup uploaded to off-server storage."
fi

backup_prune_local "${backup_dir_root}" "${retention}"
if [ "${local_only}" -eq 0 ]; then
  backup_prune_remote "${retention}"
fi
