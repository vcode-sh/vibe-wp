#!/usr/bin/env sh
set -eu
VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"
vibe_require_env_file
# SMTP_* vars (including SMTP_TEST_TO) are injected via the panel's env (sudoers
# env_keep). Do NOT source the env file here — sourcing breaks on values that
# contain spaces (e.g. SMTP_FROM_NAME="My Site") and is unnecessary now that
# env_keep preserves every SMTP_* key through sudo's env_reset.
: "${SMTP_TEST_TO:?SMTP_TEST_TO is required}"
# msmtp + the rendered /etc/msmtprc live in the wordpress container, not the host.
# Test through the container so we exercise the exact config the site will use.
if ! vibe_compose exec -T wordpress test -f /etc/msmtprc 2>/dev/null; then
  echo "SMTP relay is not active (no /etc/msmtprc in the container). Set SMTP_MODE=relay, save, and retry."
  exit 1
fi
set +e
out="$(printf 'Subject: Vibe WP SMTP test\nTo: %s\n\nThis is a Vibe WP SMTP relay test.\n' "${SMTP_TEST_TO}" \
  | vibe_compose exec -T wordpress msmtp --file /etc/msmtprc "${SMTP_TEST_TO}" 2>&1)"
code=$?
set -e
if [ "$code" -eq 0 ]; then
  printf 'Test email sent to %s.\n' "${SMTP_TEST_TO}"
else
  printf 'Test send failed (msmtp exit %s):\n%s\n' "$code" "$out"
fi
exit "$code"
