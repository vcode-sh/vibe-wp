#!/bin/sh
set -eu

PANEL_DIR=/opt/vibe-wp-panel
REPO_DIR="$(CDPATH='' cd "$(dirname "$0")/.." && pwd)"
UNIT=vibe-wp-panel
PORT=4000
# Dedicated least-privilege account the panel server runs as. It reaches the
# host ONLY through the root-owned, sudoers-gated wrapper bin/vibe-panel-run.
PANEL_USER=vibe-panel
SUDOERS_FILE=/etc/sudoers.d/vibe-wp-panel

if [ "$(id -u)" = 0 ]; then SUDO=""; else SUDO="sudo"; fi

usage() {
  echo "Usage: bin/panel <install|update|status|logs|reset-password|uninstall> [options]"
  echo ""
  echo "  install    [--access domain|magic-dns|ip-port|localhost] [--domain d] [--port N] [--admin-email e] [--admin-password P]"
  echo "             --admin-email / --admin-password are OPTIONAL: omit both and the"
  echo "             browser onboarding wizard creates the owner on first visit. Supply"
  echo "             both (or --admin-email + VIBE_PANEL_ADMIN_PASSWORD) for headless/CI."
  echo "             Env: VIBE_PANEL_ADMIN_PASSWORD — supply the owner password without exposing it in argv/ps"
  echo "  update     Rebuild + redeploy the panel from the current repo checkout"
  echo "  status     Show systemd service status"
  echo "  logs       Tail panel service logs  [-n N] [-f]"
  echo "  reset-password --email e [--password-stdin --yes]"
  echo "  uninstall  [--purge]"
  exit 1
}

cmd="${1:-}"
[ -n "$cmd" ] || usage
shift || true

DOMAIN=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
RESET_EMAIL=""
ACCESS_MODE=""
PASSWORD_STDIN=0
YES=0
PURGE=0
LOGS_FOLLOW=0
LOGS_LINES=200

die() { echo "panel: $1" >&2; exit 1; }

while [ $# -gt 0 ]; do
  case "$1" in
    --domain)         DOMAIN="$2";         shift 2 ;;
    --admin-email)    ADMIN_EMAIL="$2";    shift 2 ;;
    --admin-password) ADMIN_PASSWORD="$2"; shift 2 ;;
    --email)          RESET_EMAIL="$2";    shift 2 ;;
    --access)         ACCESS_MODE="$2";    shift 2 ;;
    --password-stdin) PASSWORD_STDIN=1;    shift ;;
    --yes)            YES=1;               shift ;;
    --port)           PORT="$2";           shift 2 ;;
    --purge)          PURGE=1;             shift ;;
    -f)               LOGS_FOLLOW=1;       shift ;;
    -n)               LOGS_LINES="$2";     shift 2 ;;
    *) usage ;;
  esac
done

# Resolve the host arch to the installer's compiled-binary suffix.
installer_arch() {
  m="$(uname -m)"
  case "$m" in
    x86_64|amd64) echo "x64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) echo "unsupported arch: $m" >&2; return 1 ;;
  esac
}

# Detect the server's public IPv4 (best-effort; empty on failure).
detect_public_ip() {
  curl -fsS https://api.ipify.org 2>/dev/null || true
}

# Resolve all access-dependent values from (ACCESS_MODE, DOMAIN, PORT).
# Sets: ACCESS_MODE ACCESS_HOST ACCESS_ORIGIN CADDY_SITE_ADDRESS CADDY_TLS_LINE
# Default mode: magic-dns when no --domain/--access given, else domain.
resolve_access() {
  if [ -z "$ACCESS_MODE" ]; then
    if [ -n "$DOMAIN" ]; then ACCESS_MODE=domain; else ACCESS_MODE=magic-dns; fi
  fi
  CADDY_TLS_LINE=""
  case "$ACCESS_MODE" in
    domain)
      [ -n "$DOMAIN" ] || die "access mode 'domain' requires --domain"
      ACCESS_HOST="$DOMAIN"
      ACCESS_ORIGIN="https://$DOMAIN"
      CADDY_SITE_ADDRESS="$DOMAIN"
      ;;
    magic-dns)
      ip="$(detect_public_ip)"
      [ -n "$ip" ] || die "magic-dns needs a detectable public IP (none found)"
      dashed="$(printf '%s' "$ip" | tr '.' '-')"
      ACCESS_HOST="panel.$dashed.sslip.io"
      ACCESS_ORIGIN="https://$ACCESS_HOST"
      CADDY_SITE_ADDRESS="$ACCESS_HOST"
      ;;
    ip-port)
      ip="$(detect_public_ip)"
      [ -n "$ip" ] || die "ip-port needs a detectable public IP (none found)"
      ACCESS_HOST="$ip"
      ACCESS_ORIGIN="https://$ip:8443"
      CADDY_SITE_ADDRESS="$ip:8443"
      CADDY_TLS_LINE="$(printf '\ttls internal')"
      ;;
    localhost)
      ACCESS_HOST="localhost"
      ACCESS_ORIGIN="https://localhost:8443"
      CADDY_SITE_ADDRESS="localhost:8443"
      CADDY_TLS_LINE="$(printf '\ttls internal')"
      ;;
    *) die "invalid --access mode: $ACCESS_MODE (use domain|magic-dns|ip-port|localhost)" ;;
  esac
}

# Is the committed dist binary missing or older than any installer source file?
installer_dist_stale() {
  bin="$1"
  [ -f "$bin" ] || return 0
  newer="$(find "$REPO_DIR/installer/src" -type f -newer "$bin" -print -quit 2>/dev/null || true)"
  [ -n "$newer" ]
}

# Place the correct-arch installer binary at $PANEL_DIR/bin/vibe-wp-installer.
# Builds from installer/ when the committed dist binary is missing or stale.
install_installer_bin() {
  arch="$(installer_arch)"
  dist="$REPO_DIR/installer/dist/vibe-wp-installer-linux-$arch"
  if installer_dist_stale "$dist"; then
    echo "Building installer binary (linux-$arch)..."
    ( cd "$REPO_DIR/installer" && "$BUN" install && "$BUN" run "build:linux-$arch" )
  fi
  [ -f "$dist" ] || { echo "installer binary not found: $dist" >&2; return 1; }
  $SUDO install -d -m 0755 "$PANEL_DIR/bin"
  $SUDO install -m 0755 "$dist" "$PANEL_DIR/bin/vibe-wp-installer"
}

# Create the dedicated least-privilege panel account if absent. Idempotent:
# re-running install/update never errors when the user already exists.
ensure_panel_user() {
  if id "$PANEL_USER" >/dev/null 2>&1; then
    return 0
  fi
  echo "Creating system user $PANEL_USER..."
  nologin="$(command -v nologin || echo /usr/sbin/nologin)"
  $SUDO useradd --system --no-create-home --shell "$nologin" "$PANEL_USER"
}

# Install the root-owned, sudoers-gated host-exec wrapper and write the sudoers
# rule that lets vibe-panel run ONLY that wrapper as root, with no password.
# The wrapper MUST stay root-owned + 0755 (never vibe-panel-writable) or the
# whole privilege boundary collapses. The sudoers file is validated with
# `visudo -cf` and removed + aborted on if it is malformed.
install_runner_and_sudoers() {
  $SUDO install -d -m 0755 "$PANEL_DIR/bin"
  # root:root 0755 — readable/executable by vibe-panel, writable only by root.
  $SUDO install -o root -g root -m 0755 \
    "$REPO_DIR/bin/vibe-panel-run" "$PANEL_DIR/bin/vibe-panel-run"

  # sudo's default env_reset strips the caller's environment, but the panel
  # injects per-op CONFIG via process env (exec.ts runVibe `opts.env`) — without
  # an env_keep these vars never reach the wrapper and the host op silently does
  # nothing (site-config-apply writes nothing; backup-config-apply disables R2).
  # Preserve EXACTLY the injected var names (a scoped env_keep, NOT a blanket
  # setenv tag — setenv would let the caller smuggle arbitrary env to root).
  #
  # SOURCE OF TRUTH: control-panel/packages/api/src/core-bridge/exec.ts callers.
  # Keep this set in sync with the env maps they pass as runVibe/streamVibe
  # `opts.env`:
  #   site-config.ts  (siteConfigApply, via site-config-pure debugPatchToEnv /
  #     imagePatchToEnv / fastcgiCachePatchToEnv / securityFixToEnv):
  #     WP_DEBUG_LOG WP_DEBUG_DISPLAY SCRIPT_DEBUG VIBE_SITE_CONFIG_KEYS
  #     WORDPRESS_IMAGE NGINX_FASTCGI_CACHE DISALLOW_FILE_EDIT VIBE_WP_DISABLE_XMLRPC
  #   backup-config.ts (backupConfigApply, via backup-config-pure toEnv + retention):
  #     VIBE_BACKUP_R2_ENABLED VIBE_BACKUP_R2_BUCKET VIBE_BACKUP_R2_PREFIX
  #     VIBE_BACKUP_RETENTION RCLONE_CONFIG_R2_TYPE RCLONE_CONFIG_R2_PROVIDER
  #     RCLONE_CONFIG_R2_ACCESS_KEY_ID RCLONE_CONFIG_R2_SECRET_ACCESS_KEY
  #     RCLONE_CONFIG_R2_ENDPOINT
  #   settings.ts (backupTest, via backup-config.ts backupTestEnv): subset of the
  #     RCLONE_CONFIG_R2_* + VIBE_BACKUP_R2_BUCKET keys above (already covered)
  #   notify-config.ts (notifyConfigApply, via notify-config-pure toEnv):
  #     VIBE_MONITOR_TELEGRAM_TOKEN VIBE_MONITOR_TELEGRAM_CHAT_ID
  #     VIBE_MONITOR_WEBHOOK_URL VIBE_MONITOR_EMAIL_TO VIBE_MONITOR_ALERT_ON_WARN
  #   smtp-config.ts (smtpConfigApply) + smtp-test (smtpTest) → smtp toEnv + SMTP_TEST_TO:
  #     SMTP_MODE SMTP_HOST SMTP_PORT SMTP_SECURE SMTP_AUTH SMTP_USER SMTP_PASSWORD SMTP_FROM SMTP_FROM_NAME SMTP_TEST_TO
  #   exec.ts runVulnFeed (securityRadar, Feature E — OPTIONAL CVE feed, OFF by
  #     default): PANEL_VULN_FEED_URL PANEL_VULN_FEED_KEY (VULN_FEED_ENV_KEYS).
  #   perf-apply.ts (perfApply, via the advisor's tunable env map — feature #5):
  #     the per-key VIBE_PERF_* size/count values + VIBE_PERF_KEYS.
  #     None are secrets; env-transport (not argv) keeps the writer contract
  #     identical to site-config-apply and metachar-free.
  #     VIBE_PERF_KEYS VIBE_PERF_PHP_FPM_PM_MAX_CHILDREN
  #     VIBE_PERF_PHP_FPM_PM_START_SERVERS VIBE_PERF_PHP_FPM_PM_MIN_SPARE_SERVERS
  #     VIBE_PERF_PHP_FPM_PM_MAX_SPARE_SERVERS VIBE_PERF_MARIADB_INNODB_BUFFER_POOL_SIZE
  #     VIBE_PERF_PHP_OPCACHE_MEMORY_CONSUMPTION VIBE_PERF_REDIS_MAXMEMORY
  #     VIBE_PERF_WP_MEMORY_LIMIT
  # The R2 secret IS in this set on purpose: the panel already holds that
  # credential, and this is the intended inbound channel — omitting it breaks
  # off-site backups. Streamed jobs (backups.ts) pass no extraEnv, so nothing
  # beyond these apply/test ops needs preserving.
  panel_env_keep="WP_DEBUG_LOG WP_DEBUG_DISPLAY SCRIPT_DEBUG VIBE_SITE_CONFIG_KEYS WORDPRESS_IMAGE NGINX_FASTCGI_CACHE DISALLOW_FILE_EDIT VIBE_WP_DISABLE_XMLRPC VIBE_BACKUP_R2_ENABLED VIBE_BACKUP_R2_BUCKET VIBE_BACKUP_R2_PREFIX VIBE_BACKUP_RETENTION RCLONE_CONFIG_R2_TYPE RCLONE_CONFIG_R2_PROVIDER RCLONE_CONFIG_R2_ACCESS_KEY_ID RCLONE_CONFIG_R2_SECRET_ACCESS_KEY RCLONE_CONFIG_R2_ENDPOINT VIBE_MONITOR_TELEGRAM_TOKEN VIBE_MONITOR_TELEGRAM_CHAT_ID VIBE_MONITOR_WEBHOOK_URL VIBE_MONITOR_EMAIL_TO VIBE_MONITOR_ALERT_ON_WARN SMTP_MODE SMTP_HOST SMTP_PORT SMTP_SECURE SMTP_AUTH SMTP_USER SMTP_PASSWORD SMTP_FROM SMTP_FROM_NAME SMTP_TEST_TO PANEL_VULN_FEED_URL PANEL_VULN_FEED_KEY VIBE_PERF_KEYS VIBE_PERF_PHP_FPM_PM_MAX_CHILDREN VIBE_PERF_PHP_FPM_PM_START_SERVERS VIBE_PERF_PHP_FPM_PM_MIN_SPARE_SERVERS VIBE_PERF_PHP_FPM_PM_MAX_SPARE_SERVERS VIBE_PERF_MARIADB_INNODB_BUFFER_POOL_SIZE VIBE_PERF_PHP_OPCACHE_MEMORY_CONSUMPTION VIBE_PERF_REDIS_MAXMEMORY VIBE_PERF_WP_MEMORY_LIMIT"

  # Write the sudoers rule to a temp file, validate it, then move into place.
  tmp_sudoers="$(mktemp)"
  {
    printf 'Defaults:%s env_keep += "%s"\n' "$PANEL_USER" "$panel_env_keep"
    printf '%s ALL=(root) NOPASSWD: %s\n' \
      "$PANEL_USER" "$PANEL_DIR/bin/vibe-panel-run"
  } > "$tmp_sudoers"
  if $SUDO visudo -cf "$tmp_sudoers" >/dev/null 2>&1; then
    $SUDO install -o root -g root -m 0440 "$tmp_sudoers" "$SUDOERS_FILE"
    rm -f "$tmp_sudoers"
  else
    rm -f "$tmp_sudoers"
    echo "panel: generated sudoers rule is invalid — aborting (no rule written)" >&2
    return 1
  fi
}

# deploy_panel: build + copy app dir + write env + db:push + restart service.
# Called by both install_panel (with a freshly-prompted DOMAIN/SECRET) and
# update_panel (with values sourced from the existing server/.env).
# Requires: BUN, DOMAIN, SECRET, PORT to be set by the caller.
deploy_panel() {
  $SUDO install -d -m 0755 "$PANEL_DIR"
  $SUDO install -d -m 0700 "$PANEL_DIR/data"

  # Least-privilege account + the root-owned host-exec wrapper + sudoers rule.
  # Done up-front so the systemd unit can run as vibe-panel and the server's
  # PANEL_PRIVILEGED_RUNNER points at a wrapper that already exists.
  ensure_panel_user
  install_runner_and_sudoers

  # Web bundles the panel's own origin for /rpc and /api/auth (Caddy routes them to the server).
  printf 'VITE_SERVER_URL=%s\n' "$ACCESS_ORIGIN" > "$REPO_DIR/control-panel/web/.env"
  ( cd "$REPO_DIR/control-panel" && "$BUN" install && "$BUN" run build )
  $SUDO rm -rf "$PANEL_DIR/app"
  $SUDO cp -R "$REPO_DIR/control-panel" "$PANEL_DIR/app"

  # Installer binary — the provisioning bridge drives this (PANEL_INSTALLER_BIN).
  install_installer_bin

  # Env (contains BETTER_AUTH_SECRET). Owned by vibe-panel + 0600: the service
  # (running as vibe-panel) can read it; nobody else can. PANEL_PRIVILEGED_RUNNER
  # makes every host op flow through the sudoers-gated wrapper.
  ( umask 077 && printf '%s\n' \
    "DATABASE_URL=file:$PANEL_DIR/data/panel.db" \
    "BETTER_AUTH_SECRET=$SECRET" \
    "BETTER_AUTH_URL=$ACCESS_ORIGIN" \
    "CORS_ORIGIN=$ACCESS_ORIGIN" \
    "NODE_ENV=production" \
    "PANEL_SITES_ROOTS=/opt:/srv" \
    "PANEL_HOST_DIR=$REPO_DIR" \
    "PANEL_INSTALLER_BIN=$PANEL_DIR/bin/vibe-wp-installer" \
    "PANEL_PRIVILEGED_RUNNER=$PANEL_DIR/bin/vibe-panel-run" \
    | $SUDO tee "$PANEL_DIR/app/server/.env" >/dev/null )
  $SUDO chown "$PANEL_USER:$PANEL_USER" "$PANEL_DIR/app/server/.env"
  $SUDO chmod 600 "$PANEL_DIR/app/server/.env"

  # DB migrate (the auth DB holds password hashes + sessions). Run as root, then
  # hand the data dir + db to vibe-panel so the service can read/write its DB.
  # drizzle-kit push cannot ALTER an existing SQLite table to add a PRIMARY KEY
  # column, so a rateLimit table created before the id-PK fix would silently
  # survive without its `id` column and 500 every sign-in (storage:database
  # reads/writes rateLimit on each auth call). The table holds only transient
  # rate-limit counters, so drop it first and let db:push recreate it with the
  # correct shape. Safe no-op when the DB or table does not yet exist.
  if [ -f "$PANEL_DIR/data/panel.db" ]; then
    PANEL_DB="$PANEL_DIR/data/panel.db" "$BUN" -e 'import {Database} from "bun:sqlite"; const d=new Database(process.env.PANEL_DB); d.run("DROP TABLE IF EXISTS rateLimit"); d.close();' 2>/dev/null || true
  fi
  ( cd "$PANEL_DIR/app" && DATABASE_URL="file:$PANEL_DIR/data/panel.db" "$BUN" run db:push )
  $SUDO chown -R "$PANEL_USER:$PANEL_USER" "$PANEL_DIR/data"
  $SUDO chmod 700 "$PANEL_DIR/data"
  $SUDO chmod 600 "$PANEL_DIR/data/panel.db" 2>/dev/null || true

  # The app dir + wrapper + installer binary stay root-owned but world-readable/
  # executable so the unprivileged vibe-panel service can read+run them (but not
  # rewrite them — that is what keeps the sudoers gate meaningful).
  # CRITICAL: server/.env holds BETTER_AUTH_SECRET + DATABASE_URL. A recursive
  # `chmod -R a+rX` would re-widen it to world-readable — even momentarily before
  # a re-tighten, that is a window where any local user can read the secret.
  # Prune server/.env from the widen so its 0600 mode is NEVER loosened at any
  # instant; everything else under app/ is still made a+rX.
  $SUDO find "$PANEL_DIR/app" -path '*/server/.env' -prune -o -exec chmod a+rX {} + 2>/dev/null || true
  # Defensively re-assert 0600 (owned by vibe-panel, so the service still reads
  # it). With the prune above this is now a belt-and-braces no-op rather than a
  # required re-tighten, but keeping it guards against any future widen path.
  $SUDO chmod 600 "$PANEL_DIR/app/server/.env"
  # Ensure the Bun runtime itself is executable by vibe-panel.
  $SUDO chmod a+rx "$BUN" 2>/dev/null || true

  # systemd service (Bun runtime) — runs as the least-privilege vibe-panel user.
  # It owns no root powers; all host operations go through sudo -n on the
  # allowlisted, validating wrapper (PANEL_PRIVILEGED_RUNNER).
  service="[Unit]
Description=Vibe WP control panel
After=network.target docker.service
[Service]
Type=simple
User=$PANEL_USER
Group=$PANEL_USER
WorkingDirectory=$PANEL_DIR/app/server
Environment=PORT=$PORT
ExecStart=$BUN run src/index.ts
Restart=always
[Install]
WantedBy=multi-user.target"

  printf '%s\n' "$service" | $SUDO tee /etc/systemd/system/$UNIT.service >/dev/null
  $SUDO systemctl daemon-reload
  $SUDO systemctl enable "$UNIT.service" >/dev/null 2>&1 || true
  $SUDO systemctl restart "$UNIT.service"
}

install_panel() {
  # Establish the access-mode default before deciding whether to prompt for a domain.
  if [ -z "$ACCESS_MODE" ]; then
    if [ -n "$DOMAIN" ]; then ACCESS_MODE=domain; else ACCESS_MODE=magic-dns; fi
  fi
  # Only 'domain' mode needs a subdomain; prompt when interactive and unset.
  if [ "$ACCESS_MODE" = domain ] && [ -z "$DOMAIN" ]; then
    printf 'Subdomain for the panel: '; read -r DOMAIN
  fi
  resolve_access
  if [ "${VIBE_PANEL_PRINT_ACCESS:-}" = "1" ]; then
    printf 'mode=%s\nhost=%s\norigin=%s\ncaddy_addr=%s\ncaddy_tls=%s\n' \
      "$ACCESS_MODE" "$ACCESS_HOST" "$ACCESS_ORIGIN" "$CADDY_SITE_ADDRESS" "$CADDY_TLS_LINE"
    return 0
  fi
  # Owner creation is OPTIONAL. Resolve the password from the env up-front (it is
  # never read from argv/ps) so we can decide whether to bootstrap an owner at all.
  # When NO owner creds are supplied AND we have an interactive TTY, offer to
  # capture them now; otherwise stay silent and let the browser onboarding wizard
  # create the owner on first visit (needsSetup stays true). Non-interactive runs
  # with no creds simply skip owner creation — they do not block on a prompt.
  [ -n "$ADMIN_PASSWORD" ] || ADMIN_PASSWORD="${VIBE_PANEL_ADMIN_PASSWORD:-}"
  if [ -z "$ADMIN_EMAIL" ] && [ -z "$ADMIN_PASSWORD" ] && [ -t 0 ]; then
    printf 'Owner email (leave blank to finish setup in the browser): '
    read -r ADMIN_EMAIL
  fi

  # Bun preflight
  if ! command -v bun >/dev/null 2>&1; then
    echo "Installing Bun..."
    curl -fsSL https://bun.sh/install | $SUDO env BUN_INSTALL=/usr/local bash
  fi
  BUN="$(command -v bun || echo /usr/local/bin/bun)"

  command -v caddy >/dev/null 2>&1 || die "Caddy is not installed. Install Caddy first (the bootstrap installer does this), then re-run."

  # DNS preflight — only meaningful when a real domain is in use
  if [ -n "$DOMAIN" ]; then
    ip="$(curl -fsS https://api.ipify.org 2>/dev/null || true)"
    resolved="$(getent ahosts "$DOMAIN" 2>/dev/null | awk 'NR==1{print $1}' || true)"
    if [ -n "$ip" ] && [ -n "$resolved" ] && [ "$resolved" != "$ip" ]; then
      echo "WARN: $DOMAIN resolves to '$resolved', server is '$ip'. Add an A record."
    fi
  fi

  # Preserve existing BETTER_AUTH_SECRET across reinstalls so sessions survive upgrades.
  # Must be read BEFORE rm -rf "$PANEL_DIR/app" removes the old .env.
  existing_secret="$($SUDO grep -m1 '^BETTER_AUTH_SECRET=' "$PANEL_DIR/app/server/.env" 2>/dev/null | cut -d= -f2- || true)"
  if [ -n "$existing_secret" ]; then
    SECRET="$existing_secret"
  else
    SECRET="$(head -c 48 /dev/urandom | base64 | tr -d '/+=' | cut -c1-44)"
  fi

  deploy_panel

  # Caddy snippet
  $SUDO install -d -m 0755 /etc/caddy/sites-enabled
  if [ ! -f /etc/caddy/Caddyfile ]; then
    printf '%s\n' 'import /etc/caddy/sites-enabled/*.caddy' | $SUDO tee /etc/caddy/Caddyfile >/dev/null
  fi
  if ! grep -q 'sites-enabled/\*.caddy' /etc/caddy/Caddyfile; then
    printf '\n%s\n' 'import /etc/caddy/sites-enabled/*.caddy' | $SUDO tee -a /etc/caddy/Caddyfile >/dev/null
  fi
  printf '%s\n' "$CADDY_SITE_ADDRESS {
$CADDY_TLS_LINE
	handle /rpc/* {
		reverse_proxy localhost:$PORT
	}
	handle /api/* {
		reverse_proxy localhost:$PORT
	}
	handle {
		root * $PANEL_DIR/app/web/dist
		try_files {path} /index.html
		file_server
	}
}" | $SUDO tee /etc/caddy/sites-enabled/vibe-wp-panel.caddy >/dev/null

  # Smoke check the local service before exposing it.
  sleep 2
  curl -fsS "http://localhost:$PORT/" >/dev/null && echo "panel: service up"

  # Expose the panel via Caddy unconditionally. With owner creation now OPTIONAL,
  # a fresh panel may legitimately come up with zero users so the browser
  # onboarding wizard can create the owner. That is SAFE because the only
  # reachable mutation before an owner exists is the completeSetup procedure,
  # which re-checks server-side that no admin exists and refuses otherwise; and
  # public better-auth sign-up is already closed by the first-user auth hook
  # (only the very first create is allowed). Do NOT add any other unauthenticated
  # mutating procedure to the pre-owner surface.
  $SUDO caddy validate --config /etc/caddy/Caddyfile && $SUDO systemctl reload caddy

  # Optional owner bootstrap (first user becomes admin via the DB hook; password
  # never echoed). When an interactive operator entered an email but no password,
  # capture it now. We only create the owner when BOTH email and password are
  # present; otherwise we skip and let the browser wizard handle it.
  if [ -n "$ADMIN_EMAIL" ] && [ -z "$ADMIN_PASSWORD" ] && [ -t 0 ]; then
    printf 'Owner password (min 8): '
    stty -echo
    read -r ADMIN_PASSWORD
    stty echo
    echo
  fi

  owner_created=0
  if [ -n "$ADMIN_EMAIL" ] && [ -n "$ADMIN_PASSWORD" ]; then
    if printf '{"email":"%s","password":"%s","name":"Owner"}' "$ADMIN_EMAIL" "$ADMIN_PASSWORD" \
      | curl -fsS -X POST "http://localhost:$PORT/api/auth/sign-up/email" \
        -H 'Content-Type: application/json' \
        --data @- >/dev/null; then
      owner_created=1
      echo "panel: owner account created"
    fi
  else
    echo "panel: no owner supplied — finish setup in the browser"
  fi

  # Always print the URL clearly so the operator knows where to go next.
  echo "Done. Open $ACCESS_ORIGIN to finish setup and sign in."
  if [ "$owner_created" = 1 ]; then
    echo "panel: owner account created — sign in at $ACCESS_ORIGIN"
  fi
}

# Fast-forward the source checkout to the latest committed code before rebuilding.
# GUARDS (fail CLEANLY rather than leave a half-updated tree):
#   - skip silently when $REPO_DIR is not a git work tree (e.g. a tarball deploy)
#     or when git is unavailable — the rebuild then ships the checked-out code;
#   - abort on a DIRTY tree (uncommitted changes) so a `--ff-only` does not clash
#     with local edits, and so we never rebuild from an inconsistent worktree;
#   - `git pull --ff-only` itself refuses to merge a diverged branch, so a
#     non-fast-forwardable remote aborts before anything is rebuilt.
pull_latest_source() {
  command -v git >/dev/null 2>&1 || { echo "panel: git not found — rebuilding the current checkout."; return 0; }
  if ! git -C "$REPO_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "panel: $REPO_DIR is not a git checkout — rebuilding the current files."
    return 0
  fi
  if [ -n "$(git -C "$REPO_DIR" status --porcelain 2>/dev/null)" ]; then
    echo "panel: refusing to pull — $REPO_DIR has uncommitted changes. Commit or stash them, then re-run." >&2
    return 1
  fi
  echo "panel: pulling latest code (git pull --ff-only)..."
  if ! git -C "$REPO_DIR" pull --ff-only; then
    echo "panel: git pull --ff-only failed (the branch has diverged from its remote). Resolve it, then re-run; nothing was rebuilt." >&2
    return 1
  fi
}

update_panel() {
  env_file="$PANEL_DIR/app/server/.env"
  if ! $SUDO test -f "$env_file"; then
    echo "panel: no existing installation found at $PANEL_DIR — run 'bin/panel install' first." >&2
    return 1
  fi

  # Pull the latest code FIRST (dirty/diverged tree aborts cleanly before any
  # rebuild). Done before the Bun preflight so a failed pull short-circuits.
  pull_latest_source

  # Bun preflight (operator may have rebooted since install)
  if ! command -v bun >/dev/null 2>&1; then
    echo "Installing Bun..."
    curl -fsSL https://bun.sh/install | $SUDO env BUN_INSTALL=/usr/local bash
  fi
  BUN="$(command -v bun || echo /usr/local/bin/bun)"

  # Source domain, secret, and port from the existing env — no re-prompting.
  # BETTER_AUTH_SECRET must be read BEFORE rm -rf "$PANEL_DIR/app" in deploy_panel.
  ACCESS_ORIGIN="$($SUDO grep -m1 '^BETTER_AUTH_URL=' "$env_file" 2>/dev/null | cut -d= -f2- || true)"
  DOMAIN="$(printf '%s' "$ACCESS_ORIGIN" | sed -e 's|^https://||' -e 's|:.*$||')"
  SECRET="$($SUDO grep -m1 '^BETTER_AUTH_SECRET=' "$env_file" 2>/dev/null | cut -d= -f2- || true)"
  existing_port="$($SUDO grep -m1 '^Environment=PORT=' /etc/systemd/system/$UNIT.service 2>/dev/null | cut -d= -f3 || true)"
  [ -n "$existing_port" ] && PORT="$existing_port"

  if [ -z "$DOMAIN" ] || [ -z "$SECRET" ]; then
    echo "panel: could not read DOMAIN or BETTER_AUTH_SECRET from $env_file" >&2
    return 1
  fi

  echo "panel: updating (domain=$DOMAIN port=$PORT)..."
  deploy_panel
  echo "panel: update complete"
}

logs_panel() {
  if [ "$LOGS_FOLLOW" = 1 ]; then
    journalctl -u "$UNIT.service" -n "$LOGS_LINES" -f
  else
    journalctl -u "$UNIT.service" -n "$LOGS_LINES"
  fi
}

status_panel() {
  systemctl status $UNIT.service --no-pager || true
}

reset_password_panel() {
  env_file="$PANEL_DIR/app/server/.env"
  if ! $SUDO test -f "$env_file"; then
    echo "panel: no existing installation found at $PANEL_DIR — run 'bin/panel install' first." >&2
    return 1
  fi
  [ -n "$RESET_EMAIL" ] || { echo "panel: --email is required" >&2; return 1; }

  if ! command -v bun >/dev/null 2>&1; then
    echo "Installing Bun..."
    curl -fsSL https://bun.sh/install | $SUDO env BUN_INSTALL=/usr/local bash
  fi
  BUN="$(command -v bun || echo /usr/local/bin/bun)"

  if [ "$PASSWORD_STDIN" = 1 ]; then
    if [ "$YES" != 1 ]; then
      echo "panel: --password-stdin requires --yes" >&2
      return 1
    fi
    ( cd "$PANEL_DIR/app/server" && "$BUN" run src/cli/reset-password.ts --email "$RESET_EMAIL" --password-stdin )
    return
  fi

  if [ ! -t 0 ]; then
    echo "panel: interactive reset requires a TTY; use --password-stdin --yes for automation" >&2
    return 1
  fi

  printf 'New password for %s: ' "$RESET_EMAIL"
  stty -echo
  read -r NEW_PASSWORD
  stty echo
  echo
  printf 'Repeat new password: '
  stty -echo
  read -r NEW_PASSWORD_CONFIRM
  stty echo
  echo

  if [ "$NEW_PASSWORD" != "$NEW_PASSWORD_CONFIRM" ]; then
    NEW_PASSWORD=""
    NEW_PASSWORD_CONFIRM=""
    echo "panel: passwords do not match" >&2
    return 1
  fi

  printf 'This will reset the panel password for %s and revoke existing sessions. Type RESET to continue: ' "$RESET_EMAIL"
  read -r CONFIRM
  if [ "$CONFIRM" != "RESET" ]; then
    NEW_PASSWORD=""
    NEW_PASSWORD_CONFIRM=""
    echo "panel: aborted"
    return 1
  fi

  printf '%s\n' "$NEW_PASSWORD" | ( cd "$PANEL_DIR/app/server" && "$BUN" run src/cli/reset-password.ts --email "$RESET_EMAIL" --password-stdin )
  NEW_PASSWORD=""
  NEW_PASSWORD_CONFIRM=""
}

uninstall_panel() {
  $SUDO systemctl disable --now $UNIT.service 2>/dev/null || true
  $SUDO rm -f /etc/systemd/system/$UNIT.service /etc/caddy/sites-enabled/vibe-wp-panel.caddy
  # Drop the sudoers grant so the boundary can never linger after teardown.
  $SUDO rm -f "$SUDOERS_FILE"
  $SUDO systemctl daemon-reload
  if command -v caddy >/dev/null 2>&1; then
    $SUDO caddy validate --config /etc/caddy/Caddyfile && $SUDO systemctl reload caddy || true
  fi
  if [ "$PURGE" = 1 ]; then
    $SUDO rm -rf "$PANEL_DIR"
    # Remove the dedicated account too on a purge (idempotent / best-effort).
    if id "$PANEL_USER" >/dev/null 2>&1; then
      $SUDO userdel "$PANEL_USER" 2>/dev/null || true
    fi
    echo "panel: purged"
  fi
  echo "panel: uninstalled"
}

case "$cmd" in
  install)   install_panel ;;
  update)    update_panel ;;
  status)    status_panel ;;
  logs)      logs_panel ;;
  reset-password) reset_password_panel ;;
  uninstall) uninstall_panel ;;
  *)         usage ;;
esac
