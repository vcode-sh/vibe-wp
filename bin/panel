#!/bin/sh
set -eu

PANEL_DIR=/opt/vibe-wp-panel
REPO_DIR="$(CDPATH='' cd "$(dirname "$0")/.." && pwd)"
UNIT=vibe-wp-panel
PORT=4000

if [ "$(id -u)" = 0 ]; then SUDO=""; else SUDO="sudo"; fi

usage() {
  echo "Usage: bin/panel <install|status|uninstall> [--domain d --admin-email e --port N --admin-password P --purge]"
  exit 1
}

cmd="${1:-}"
[ -n "$cmd" ] || usage
shift || true

DOMAIN=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
PURGE=0

while [ $# -gt 0 ]; do
  case "$1" in
    --domain)         DOMAIN="$2";         shift 2 ;;
    --admin-email)    ADMIN_EMAIL="$2";    shift 2 ;;
    --admin-password) ADMIN_PASSWORD="$2"; shift 2 ;;
    --port)           PORT="$2";           shift 2 ;;
    --purge)          PURGE=1;             shift ;;
    *) usage ;;
  esac
done

install_panel() {
  [ -n "$DOMAIN" ] || { printf 'Subdomain for the panel: '; read -r DOMAIN; }
  [ -n "$ADMIN_EMAIL" ] || { printf 'Owner email: '; read -r ADMIN_EMAIL; }

  # Bun preflight
  if ! command -v bun >/dev/null 2>&1; then
    echo "Installing Bun..."
    curl -fsSL https://bun.sh/install | $SUDO env BUN_INSTALL=/usr/local bash
  fi
  BUN="$(command -v bun || echo /usr/local/bin/bun)"

  # DNS preflight
  ip="$(curl -fsS https://api.ipify.org 2>/dev/null || true)"
  resolved="$(getent ahosts "$DOMAIN" 2>/dev/null | awk 'NR==1{print $1}' || true)"
  if [ -n "$ip" ] && [ -n "$resolved" ] && [ "$resolved" != "$ip" ]; then
    echo "WARN: $DOMAIN resolves to '$resolved', server is '$ip'. Add an A record."
  fi

  # Preserve existing BETTER_AUTH_SECRET across reinstalls so sessions survive upgrades.
  # Must be read BEFORE rm -rf "$PANEL_DIR/app" removes the old .env.
  existing_secret="$($SUDO grep -m1 '^BETTER_AUTH_SECRET=' "$PANEL_DIR/app/server/.env" 2>/dev/null | cut -d= -f2- || true)"

  # Build
  $SUDO install -d -m 0755 "$PANEL_DIR"
  $SUDO install -d -m 0700 "$PANEL_DIR/data"
  # Web bundles the panel's own origin for /rpc and /api/auth (Caddy routes them to the server).
  printf 'VITE_SERVER_URL=https://%s\n' "$DOMAIN" > "$REPO_DIR/control-panel/web/.env"
  ( cd "$REPO_DIR/control-panel" && "$BUN" install && "$BUN" run build )
  $SUDO rm -rf "$PANEL_DIR/app"
  $SUDO cp -R "$REPO_DIR/control-panel" "$PANEL_DIR/app"

  # Env (contains BETTER_AUTH_SECRET — keep it root-only, never world-readable)
  if [ -n "$existing_secret" ]; then
    SECRET="$existing_secret"
  else
    SECRET="$(head -c 48 /dev/urandom | base64 | tr -d '/+=' | cut -c1-44)"
  fi
  ( umask 077 && printf '%s\n' \
    "DATABASE_URL=file:$PANEL_DIR/data/panel.db" \
    "BETTER_AUTH_SECRET=$SECRET" \
    "BETTER_AUTH_URL=https://$DOMAIN" \
    "CORS_ORIGIN=https://$DOMAIN" \
    "NODE_ENV=production" \
    "PANEL_SITES_ROOTS=/opt:/srv" \
    | $SUDO tee "$PANEL_DIR/app/server/.env" >/dev/null )
  $SUDO chmod 600 "$PANEL_DIR/app/server/.env"

  # DB migrate (the auth DB holds password hashes + sessions — keep it root-only)
  ( cd "$PANEL_DIR/app" && DATABASE_URL="file:$PANEL_DIR/data/panel.db" "$BUN" run db:push )
  $SUDO chmod 600 "$PANEL_DIR/data/panel.db" 2>/dev/null || true

  # systemd service (Bun runtime). The MVP runs as root for full host access
  # to site operations (backup writes, docker), matching the existing
  # vibe-wp-backup/monitor timers. A dedicated least-privilege user + a
  # sudoers allowlist for the site bin/vibe entrypoints is a fan-out hardening
  # item; the exec-layer command allowlist remains the primary control.
  $SUDO chmod -R a+rX "$PANEL_DIR/app/web/dist" 2>/dev/null || true

  service="[Unit]
Description=Vibe WP control panel
After=network.target docker.service
[Service]
Type=simple
WorkingDirectory=$PANEL_DIR/app/server
Environment=PORT=$PORT
ExecStart=$BUN run src/index.ts
Restart=always
[Install]
WantedBy=multi-user.target"

  printf '%s\n' "$service" | $SUDO tee /etc/systemd/system/$UNIT.service >/dev/null
  $SUDO systemctl daemon-reload
  $SUDO systemctl enable "$UNIT.service" >/dev/null 2>&1 || true
  $SUDO systemctl restart "$UNIT.service"

  # Caddy snippet
  $SUDO install -d -m 0755 /etc/caddy/sites-enabled
  if [ ! -f /etc/caddy/Caddyfile ]; then
    printf '%s\n' 'import /etc/caddy/sites-enabled/*.caddy' | $SUDO tee /etc/caddy/Caddyfile >/dev/null
  fi
  if ! grep -q 'sites-enabled/\*.caddy' /etc/caddy/Caddyfile; then
    printf '\n%s\n' 'import /etc/caddy/sites-enabled/*.caddy' | $SUDO tee -a /etc/caddy/Caddyfile >/dev/null
  fi
  printf '%s\n' "$DOMAIN {
	handle /rpc/* {
		reverse_proxy localhost:$PORT
	}
	handle /api/* {
		reverse_proxy localhost:$PORT
	}
	handle {
		root * $PANEL_DIR/app/web/dist
		try_files {path} /index.html
		file_server
	}
}" | $SUDO tee /etc/caddy/sites-enabled/vibe-wp-panel.caddy >/dev/null

  # Smoke + owner bootstrap (first user becomes admin via the DB hook; password never echoed)
  sleep 2
  curl -fsS "http://localhost:$PORT/" >/dev/null && echo "panel: service up"
  if [ -z "$ADMIN_PASSWORD" ]; then
    printf 'Owner password (min 8): '
    stty -echo
    read -r ADMIN_PASSWORD
    stty echo
    echo
  fi
  printf '{"email":"%s","password":"%s","name":"Owner"}' "$ADMIN_EMAIL" "$ADMIN_PASSWORD" \
    | curl -fsS -X POST "http://localhost:$PORT/api/auth/sign-up/email" \
      -H 'Content-Type: application/json' \
      --data @- >/dev/null \
    && echo "panel: owner account created"

  # Expose the public domain only AFTER the owner exists, so the panel never
  # serves publicly with zero users (closes a first-install sign-up race window).
  $SUDO caddy validate --config /etc/caddy/Caddyfile && $SUDO systemctl reload caddy
  echo "Done. Open https://$DOMAIN and sign in."
}

status_panel() {
  systemctl status $UNIT.service --no-pager || true
}

uninstall_panel() {
  $SUDO systemctl disable --now $UNIT.service 2>/dev/null || true
  $SUDO rm -f /etc/systemd/system/$UNIT.service /etc/caddy/sites-enabled/vibe-wp-panel.caddy
  $SUDO systemctl daemon-reload
  if command -v caddy >/dev/null 2>&1; then
    $SUDO caddy validate --config /etc/caddy/Caddyfile && $SUDO systemctl reload caddy || true
  fi
  if [ "$PURGE" = 1 ]; then
    $SUDO rm -rf "$PANEL_DIR"
    echo "panel: purged"
  fi
  echo "panel: uninstalled"
}

case "$cmd" in
  install)   install_panel ;;
  status)    status_panel ;;
  uninstall) uninstall_panel ;;
  *)         usage ;;
esac
