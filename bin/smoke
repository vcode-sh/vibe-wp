#!/usr/bin/env sh
set -eu

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"

JSON=0
for _arg in "$@"; do
  case "${_arg}" in
    --json) JSON=1 ;;
  esac
done

failures=0
_check_count=0
_names=""
_oks=""

json_str() {
  printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')"
}

fail() {
  if [ "${JSON}" = 0 ]; then
    echo "failed: $*" >&2
  fi
  failures=$((failures + 1))
  _check_count=$((_check_count + 1))
  _label="$*"
  if [ -z "${_names}" ]; then
    _names="${_label}"
    _oks="0"
  else
    _names="${_names}	${_label}"
    _oks="${_oks}	0"
  fi
}

ok() {
  if [ "${JSON}" = 0 ]; then
    echo "ok: $*"
  fi
  _check_count=$((_check_count + 1))
  _label="$*"
  if [ -z "${_names}" ]; then
    _names="${_label}"
    _oks="1"
  else
    _names="${_names}	${_label}"
    _oks="${_oks}	1"
  fi
}

site_url="${WP_HOME:-http://localhost:${HTTP_PORT:-8080}}"

if [ -f "${VIBE_ENV_FILE}" ]; then
  vibe_load_env
  site_url="${WP_HOME:-${site_url}}"
fi

if "${VIBE_BIN_DIR}/doctor-runtime" >/dev/null; then
  ok "runtime doctor"
else
  fail "runtime doctor"
fi

vibe_clear_nginx_cache

first_headers="$(mktemp)"
second_headers="$(mktemp)"
trap 'rm -f "${first_headers}" "${second_headers}"' EXIT INT TERM

# Retry the first request briefly: a freshly (re)started stack can still be
# warming up (TLS provisioning, healthchecks), and we don't want a transient
# 5xx to fail the smoke test.
first_ok=0
i=0
while [ "${i}" -lt 10 ]; do
  if curl -fsS -o /dev/null -D "${first_headers}" "${site_url}/"; then
    first_ok=1
    break
  fi
  i=$((i + 1))
  sleep 3
done
if [ "${first_ok}" = 1 ]; then
  ok "HTTP request succeeds"
else
  fail "HTTP request failed for ${site_url}/"
fi

if curl -fsS -o /dev/null -D "${second_headers}" "${site_url}/"; then
  ok "second HTTP request succeeds"
else
  fail "second HTTP request failed for ${site_url}/"
fi

if grep -qi '^X-FastCGI-Cache: HIT' "${second_headers}"; then
  ok "Nginx FastCGI cache reaches HIT"
else
  fail "Nginx FastCGI cache did not reach HIT"
fi

if vibe_wp eval '$u = wp_upload_dir("2099/12"); if ($u["error"]) { fwrite(STDERR, $u["error"] . PHP_EOL); exit(1); } file_put_contents($u["path"] . "/vibe-wp-smoke.txt", "ok"); echo $u["path"];' >/tmp/vibe-wp-smoke-upload-path 2>/tmp/vibe-wp-smoke-upload-error; then
  upload_path="$(cat /tmp/vibe-wp-smoke-upload-path)"
  ok "WordPress can create future year/month upload directories"
else
  cat /tmp/vibe-wp-smoke-upload-error >&2 || true
  fail "WordPress upload directory creation failed"
  upload_path=""
fi

if [ -n "${upload_path}" ]; then
  if vibe_compose exec -T wordpress sh -lc 'test "$(stat -c "%U:%G %a" /var/www/html/wp-content/uploads/2099/12/vibe-wp-smoke.txt)" = "www-data:www-data 644"'; then
    ok "upload smoke file owner/mode is www-data:www-data 644"
  else
    fail "upload smoke file owner/mode is unexpected"
  fi

  vibe_compose exec -T wordpress sh -lc 'rm -f /var/www/html/wp-content/uploads/2099/12/vibe-wp-smoke.txt; rmdir /var/www/html/wp-content/uploads/2099/12 /var/www/html/wp-content/uploads/2099 2>/dev/null || true' >/dev/null 2>&1 || true
fi

rm -f /tmp/vibe-wp-smoke-upload-path /tmp/vibe-wp-smoke-upload-error

if [ "${JSON}" = 1 ]; then
  _passed="true"
  if [ "${failures}" -ne 0 ]; then
    _passed="false"
  fi
  printf '{"passed":%s,"checks":[' "${_passed}"
  _i=0
  _n_rest="${_names}"
  _o_rest="${_oks}"
  while [ "${_i}" -lt "${_check_count}" ]; do
    _n="${_n_rest%%	*}"
    _o="${_o_rest%%	*}"
    if [ "${_n_rest}" = "${_n}" ]; then
      _n_rest=""
      _o_rest=""
    else
      _n_rest="${_n_rest#*	}"
      _o_rest="${_o_rest#*	}"
    fi
    if [ "${_i}" -gt 0 ]; then
      printf ','
    fi
    _ok_val="false"
    if [ "${_o}" = "1" ]; then
      _ok_val="true"
    fi
    printf '{"name":%s,"ok":%s}' "$(json_str "${_n}")" "${_ok_val}"
    _i=$((_i + 1))
  done
  printf ']\n}\n'
fi

if [ "${failures}" -ne 0 ]; then
  if [ "${JSON}" = 0 ]; then
    echo "smoke test found ${failures} issue(s)." >&2
  fi
  exit 1
fi

if [ "${JSON}" = 0 ]; then
  echo "smoke test passed."
fi
