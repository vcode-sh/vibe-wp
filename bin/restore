#!/usr/bin/env sh
set -eu

VIBE_BIN_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "${VIBE_BIN_DIR}/lib/vibe.sh"

usage() {
  cat <<'USAGE'
Usage:
  ./bin/restore backups/<env>/<timestamp> --yes [--old-url OLD] [--new-url NEW] [--staging]

Restores:
  - database.sql.gz or database.sql
  - wp-content.tar.gz

The --yes flag is required because this replaces the current database and
wp-content files for the selected VIBE_ENV.
USAGE
}

backup_dir=""
confirm=0
old_url=""
new_url=""
staging=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes)
      confirm=1
      shift
      ;;
    --old-url)
      old_url="${2:-}"
      shift 2
      ;;
    --new-url)
      new_url="${2:-}"
      shift 2
      ;;
    --staging)
      staging=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [ -n "${backup_dir}" ]; then
        echo "Only one backup directory can be provided." >&2
        usage >&2
        exit 1
      fi
      backup_dir="$1"
      shift
      ;;
  esac
done

if [ -z "${backup_dir}" ]; then
  usage >&2
  exit 1
fi

if [ "${confirm}" != "1" ]; then
  echo "Refusing to restore without --yes." >&2
  usage >&2
  exit 1
fi

if [ ! -d "${backup_dir}" ]; then
  echo "Backup directory not found: ${backup_dir}" >&2
  exit 1
fi

if [ ! -f "${backup_dir}/database.sql.gz" ] && [ ! -f "${backup_dir}/database.sql" ]; then
  echo "No database.sql.gz or database.sql found in ${backup_dir}." >&2
  exit 1
fi

if [ ! -f "${backup_dir}/wp-content.tar.gz" ]; then
  echo "No wp-content.tar.gz found in ${backup_dir}." >&2
  exit 1
fi

echo "Starting required services..."
vibe_require_env_file
services="wordpress"
if vibe_compose_service_exists db; then
  services="db ${services}"
fi
if vibe_compose_service_exists redis; then
  services="redis ${services}"
fi
# shellcheck disable=SC2086
vibe_compose up -d ${services} >/dev/null

echo "Resetting WordPress database..."
vibe_wp db reset --yes >/dev/null

echo "Restoring database..."
if [ -f "${backup_dir}/database.sql.gz" ]; then
  if vibe_compose_service_exists db; then
    gunzip -c "${backup_dir}/database.sql.gz" | vibe_compose exec -T db sh -c 'mariadb -u"$MARIADB_USER" -p"$MARIADB_PASSWORD" "$MARIADB_DATABASE"'
  else
    gunzip -c "${backup_dir}/database.sql.gz" | vibe_wp_stdin db import -
  fi
else
  if vibe_compose_service_exists db; then
    vibe_compose exec -T db sh -c 'mariadb -u"$MARIADB_USER" -p"$MARIADB_PASSWORD" "$MARIADB_DATABASE"' < "${backup_dir}/database.sql"
  else
    vibe_wp_stdin db import - < "${backup_dir}/database.sql"
  fi
fi

echo "Restoring wp-content..."
vibe_compose exec -T wordpress sh -lc 'find /var/www/html/wp-content -mindepth 1 -maxdepth 1 -exec rm -rf {} +; mkdir -p /var/www/html/wp-content/uploads /var/www/html/wp-content/plugins /var/www/html/wp-content/themes /var/www/html/wp-content/mu-plugins'
vibe_compose exec -T wordpress tar -xzf - -C /var/www/html/wp-content < "${backup_dir}/wp-content.tar.gz"
vibe_compose exec -T wordpress sh -lc 'mkdir -p /var/www/html/wp-content/uploads /var/www/html/wp-content/plugins /var/www/html/wp-content/themes /var/www/html/wp-content/mu-plugins; touch /var/www/html/wp-content/uploads/.gitkeep /var/www/html/wp-content/plugins/.gitkeep /var/www/html/wp-content/themes/.gitkeep /var/www/html/wp-content/mu-plugins/.gitkeep'

echo "Normalizing wp-content permissions through the WordPress container..."
vibe_restart_php_and_nginx

if [ -n "${old_url}" ] || [ -n "${new_url}" ]; then
  if [ -z "${old_url}" ] || [ -z "${new_url}" ]; then
    echo "Both --old-url and --new-url are required for search-replace." >&2
    exit 1
  fi

  echo "Running URL search-replace..."
  vibe_wp search-replace "${old_url}" "${new_url}" --all-tables --precise --skip-columns=guid
fi

if [ "${staging}" = "1" ]; then
  echo "Applying staging safeguards..."
  vibe_wp option update blog_public 0 >/dev/null
  vibe_wp option update default_ping_status closed >/dev/null || true
  vibe_wp option update default_comment_status closed >/dev/null || true
fi

echo "Flushing caches..."
vibe_wp cache flush >/dev/null || true
vibe_clear_nginx_cache

echo "Restore complete from ${backup_dir}."
