{
  admin off
  auto_https off
}

:8080 {
  root * /srv
  encode zstd gzip

  header /install.sh Content-Type "text/x-shellscript; charset=utf-8"
  header /install.sh Cache-Control "public, max-age=60, must-revalidate"
  header /manifest.json Cache-Control "public, max-age=60, must-revalidate"
  header /checksums.txt Cache-Control "public, max-age=60, must-revalidate"
  header /releases/* Cache-Control "public, max-age=31536000, immutable"
  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
  }

  file_server
}
