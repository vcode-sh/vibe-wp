BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=file:../local.db

# How often (minutes) the panel records an uptime/cert/DNS sample for every site
# in the background, so the Monitoring history builds up without anyone opening
# the page. Clamped to 5..1440; set to 0 or off to disable the timer (operators
# then capture snapshots with the "Check now" button). Default 15.
# PANEL_MONITOR_RECORD_MINUTES=15
